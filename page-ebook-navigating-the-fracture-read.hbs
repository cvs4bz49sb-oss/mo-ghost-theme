<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Navigating the Fracture &mdash; Mere Orthodoxy</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IM+Fell+Great+Primer:ital@0;1&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;1,8..60,300;1,8..60,400;1,8..60,600&display=swap" rel="stylesheet">
  <style>
    /* ===== CSS Reset & Base ===== */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --primary: #ee7d51;
      --secondary: #c1593c;
      --tertiary: #a43a27;
      --quaternary: #d89f5b;
      --body-text: #2d2927;
      --light-text: #9a8773;
      --dark-bg: #c0b2a5;
      --light-bg: #f6f3f2;
      --page-bg: #f1e0c9;
      --font-headline: 'IM Fell Great Primer', 'Georgia', serif;
      --font-body: 'Source Serif 4', 'Georgia', serif;
      --content-width: 680px;
      --sidebar-width: 260px;
    }

    /* ===== Dark Mode ===== */
    [data-theme="dark"] {
      --page-bg: #2d2927;
      --body-text: #e8ddd0;
      --light-text: #9a8773;
      --primary: #ee7d51;
      --secondary: #d4826a;
      --tertiary: #e8a08a;
      --quaternary: #d89f5b;
    }

    /* ===== Body ===== */
    html {
      scroll-behavior: smooth;
      scroll-padding-top: 5rem;
    }

    body {
      font-family: var(--font-body);
      font-size: 19px;
      line-height: 1.75;
      color: var(--body-text);
      background-color: var(--page-bg);
      transition: background-color 0.3s ease, color 0.3s ease;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* ===== Layout ===== */
    .page-wrapper {
      display: flex;
      min-height: 100vh;
    }

    /* ===== Header Bar ===== */
    .top-bar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.25rem 2.5rem;
      background-color: var(--page-bg);
      transition: background-color 0.3s ease;
    }

    .org-name {
      font-family: var(--font-headline);
      font-size: 1.1rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--body-text);
      text-decoration: none;
      font-weight: 400;
    }

    .org-name:hover {
      color: var(--secondary);
    }

    /* ===== Theme Toggle ===== */
    .theme-toggle {
      position: relative;
      width: 52px;
      height: 28px;
      border-radius: 14px;
      border: 2px solid var(--body-text);
      background: transparent;
      cursor: pointer;
      transition: all 0.3s ease;
      padding: 0;
    }

    .theme-toggle::after {
      content: '';
      position: absolute;
      top: 3px;
      left: 4px;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background-color: var(--body-text);
      transition: transform 0.3s ease, background-color 0.3s ease;
    }

    [data-theme="dark"] .theme-toggle::after {
      transform: translateX(22px);
    }

    /* ===== Sidebar ===== */
    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      width: var(--sidebar-width);
      height: 100vh;
      padding: 5.5rem 2rem 2rem 2.5rem;
      overflow-y: auto;
      z-index: 10;
      display: flex;
      flex-direction: column;
      transition: transform 0.3s ease;
    }

    .sidebar.collapsed {
      transform: translateX(-100%);
    }

    .sidebar nav {
      flex: 1;
    }

    .sidebar-actions {
      margin-top: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      padding-bottom: 1rem;
    }

    /* ===== About Button ===== */
    .about-btn {
      display: block;
      text-align: center;
      width: 100%;
      padding: 0.6rem 1.4rem;
      font-family: var(--font-body);
      font-size: 0.9rem;
      color: var(--body-text);
      background: transparent;
      border: 2px solid var(--secondary);
      border-radius: 4px;
      text-decoration: none;
      cursor: pointer;
      transition: all 0.2s ease;
      margin-bottom: 0.25rem;
    }

    .about-btn:hover {
      background-color: var(--secondary);
      color: var(--page-bg);
    }

    [data-theme="dark"] .about-btn {
      border-color: var(--quaternary);
      color: var(--body-text);
    }

    [data-theme="dark"] .about-btn:hover {
      background-color: var(--quaternary);
      color: #2d2927;
    }

    /* ===== Icon Button Row ===== */
    .icon-btn-row {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
    }

    /* ===== Share Button & Popup ===== */
    .share-wrapper {
      position: relative;
    }

    .share-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 38px;
      height: 38px;
      padding: 0;
      color: var(--secondary);
      background: transparent;
      border: 2px solid var(--secondary);
      border-radius: 50%;
      text-decoration: none;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .share-btn svg {
      width: 15px;
      height: 15px;
    }

    .share-btn:hover {
      background-color: var(--secondary);
      color: var(--page-bg);
    }

    [data-theme="dark"] .share-btn {
      border-color: var(--quaternary);
      color: var(--quaternary);
    }

    [data-theme="dark"] .share-btn:hover {
      background-color: var(--quaternary);
      color: #2d2927;
    }

    .share-popup {
      display: none;
      position: absolute;
      bottom: calc(100% + 0.5rem);
      left: 50%;
      transform: translateX(-50%);
      width: 200px;
      background-color: var(--page-bg);
      border: 1px solid var(--dark-bg);
      border-radius: 6px;
      padding: 0.5rem 0;
      box-shadow: 0 4px 16px rgba(0,0,0,0.12);
      z-index: 60;
    }

    .share-popup.open {
      display: block;
    }

    [data-theme="dark"] .share-popup {
      border-color: var(--light-text);
      box-shadow: 0 4px 16px rgba(0,0,0,0.3);
    }

    .share-option {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      width: 100%;
      padding: 0.5rem 1rem;
      font-family: var(--font-body);
      font-size: 0.85rem;
      color: var(--body-text);
      background: none;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: background-color 0.15s ease;
    }

    .share-option:hover {
      background-color: var(--dark-bg);
    }

    [data-theme="dark"] .share-option:hover {
      background-color: rgba(255,255,255,0.08);
    }

    .share-option svg {
      flex-shrink: 0;
      width: 18px;
      height: 18px;
    }

    .share-copied {
      font-size: 0.8rem;
      color: var(--secondary);
      text-align: center;
      padding: 0.25rem 0;
      display: none;
    }

    .share-copied.show {
      display: block;
    }

    .toc-title {
      font-family: var(--font-headline);
      font-size: 1.05rem;
      font-weight: 400;
      color: var(--body-text);
      margin-bottom: 1.5rem;
      letter-spacing: 0.02em;
    }

    .toc-list {
      list-style: none;
      padding: 0;
    }

    .toc-list li {
      margin-bottom: 0.35rem;
    }

    .toc-list a {
      font-family: var(--font-body);
      font-size: 0.9rem;
      line-height: 1.5;
      color: var(--light-text);
      text-decoration: none;
      transition: color 0.2s ease;
      display: block;
      padding: 0.15rem 0;
    }

    .toc-list a:hover {
      color: var(--body-text);
    }

    .toc-list a.active {
      color: var(--secondary);
      font-weight: 600;
    }

    .toc-list .toc-major {
      font-family: var(--font-headline);
      font-size: 0.95rem;
      color: var(--light-text);
      margin-top: 0.5rem;
      transition: color 0.2s ease, font-weight 0.2s ease;
    }

    .toc-list .toc-major:hover {
      color: var(--body-text);
    }

    .toc-list .toc-major.active {
      color: var(--secondary);
      font-weight: 600;
    }

    .toc-list .toc-major:first-child {
      margin-top: 0;
    }

    .toc-list .toc-sub {
      padding-left: 0;
    }

    /* ===== Main Content ===== */
    .main-content {
      margin-left: var(--sidebar-width);
      flex: 1;
      padding: 6rem 4rem 6rem 4rem;
      max-width: calc(var(--content-width) + var(--sidebar-width) + 8rem);
    }

    .content-container {
      max-width: var(--content-width);
    }

    /* ===== Hero ===== */
    .hero {
      margin-bottom: 3.5rem;
      padding-bottom: 0;
    }

    .hero-title {
      font-family: var(--font-headline);
      font-size: clamp(2.8rem, 5.5vw, 4.2rem);
      line-height: 1.12;
      font-weight: 400;
      color: var(--body-text);
      margin-bottom: 0.6rem;
      letter-spacing: -0.01em;
    }

    .hero-subtitle {
      font-family: var(--font-headline);
      font-style: italic;
      font-size: clamp(1.1rem, 2vw, 1.35rem);
      color: var(--body-text);
      margin-bottom: 1.5rem;
      line-height: 1.4;
    }

    .hero-date {
      font-family: var(--font-body);
      font-size: 0.95rem;
      color: var(--light-text);
    }

    /* ===== Sections ===== */
    .content-section {
      margin-bottom: 1rem;
    }

    .section-label {
      font-family: var(--font-headline);
      font-size: 0.95rem;
      font-weight: 400;
      color: var(--light-text);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-bottom: 0.75rem;
      margin-top: 3rem;
    }

    .content-section:first-child .section-label {
      margin-top: 0;
    }

    .section-title {
      font-family: var(--font-headline);
      font-size: clamp(2rem, 4vw, 2.8rem);
      font-weight: 400;
      color: var(--body-text);
      margin-top: 4rem;
      margin-bottom: 1.5rem;
      line-height: 1.2;
      padding-top: 2rem;
      border-top: 3px solid var(--secondary);
    }

    .essay-heading {
      font-family: var(--font-headline);
      font-size: 1.15rem;
      font-weight: 400;
      color: var(--body-text);
      margin-bottom: 1.75rem;
      line-height: 1.5;
    }

    .essay-author {
      font-family: var(--font-headline);
      font-style: italic;
      font-size: 1rem;
      color: var(--light-text);
      margin-bottom: 1.75rem;
    }

    .section-heading {
      font-family: var(--font-headline);
      font-size: 1.5rem;
      font-weight: 400;
      color: var(--body-text);
      margin-top: 3rem;
      margin-bottom: 1rem;
      line-height: 1.35;
    }

    .subsection-heading {
      font-family: var(--font-headline);
      font-style: italic;
      font-size: 1.25rem;
      font-weight: 400;
      color: var(--body-text);
      margin-top: 2.5rem;
      margin-bottom: 0.75rem;
      line-height: 1.4;
    }

    /* ===== Body Text ===== */
    p {
      margin-bottom: 1.25rem;
    }

    strong {
      font-weight: 600;
    }

    em {
      font-style: italic;
    }

    /* ===== Callout (bold+italic manifesto statement) ===== */
    .callout {
      font-family: var(--font-headline);
      font-style: italic;
      font-weight: 400;
      font-size: 1.05rem;
      line-height: 1.7;
      color: var(--body-text);
      padding: 2rem 0;
      margin: 2rem 0;
      border-top: 3px solid var(--secondary);
      border-bottom: 3px solid var(--secondary);
    }

    .callout strong {
      font-weight: 400;
    }

    /* ===== Blockquote ===== */
    blockquote {
      margin: 1.75rem 0;
      padding: 0.25rem 0 0.25rem 1.75rem;
      border-left: 3px solid var(--quaternary);
      color: var(--body-text);
      font-size: 0.95rem;
      line-height: 1.8;
    }

    /* ===== Ordered/Unordered Lists ===== */
    .barna-list {
      margin: 1.5rem 0 1.5rem 1.5rem;
      padding: 0;
    }

    .barna-list li {
      margin-bottom: 0.5rem;
      padding-left: 0.25rem;
      font-size: 0.95rem;
      line-height: 1.65;
    }

    /* ===== Hamburger Menu ===== */
    .menu-toggle {
      display: block;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
      z-index: 200;
    }

    .menu-toggle span {
      display: block;
      width: 22px;
      height: 2px;
      background-color: var(--body-text);
      margin: 5px 0;
      transition: all 0.3s ease;
    }

    .sidebar-overlay {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(45, 41, 39, 0.4);
      z-index: 5;
    }


    /* ===== Responsive ===== */
    @media (max-width: 960px) {
      .sidebar {
        transform: translateX(-100%);
        transition: transform 0.3s ease;
        background-color: var(--page-bg);
        z-index: 50;
        width: 280px;
      }

      .sidebar.open {
        transform: translateX(0);
      }

      .sidebar-overlay.open {
        display: block;
      }

      .main-content {
        margin-left: 0;
        padding: 5.5rem 1.5rem 4rem 1.5rem;
      }

      .hero-title {
        font-size: 2.4rem;
      }

      .section-title {
        font-size: 2rem;
      }

      .top-bar {
        padding: 1rem 1.5rem;
      }
    }

    @media (max-width: 600px) {
      body {
        font-size: 17px;
      }

      .hero-title {
        font-size: 2rem;
      }

      .section-title {
        font-size: 1.7rem;
      }

      .section-heading {
        font-size: 1.3rem;
      }

      .main-content {
        padding: 5rem 1.25rem 3rem 1.25rem;
      }
    }

    /* ===== Download Popup ===== */
    .icon-btn-row .download-wrapper {
      flex: 1;
    }

    .download-wrapper {
      position: relative;
    }

    .download-popup {
      display: none;
      position: absolute;
      bottom: calc(100% + 0.5rem);
      left: 50%;
      transform: translateX(-50%);
      width: 180px;
      background-color: var(--page-bg);
      border: 1px solid var(--dark-bg);
      border-radius: 6px;
      padding: 0.5rem 0;
      box-shadow: 0 4px 16px rgba(0,0,0,0.12);
      z-index: 60;
    }

    .download-popup.open {
      display: block;
    }

    [data-theme="dark"] .download-popup {
      border-color: var(--light-text);
      box-shadow: 0 4px 16px rgba(0,0,0,0.3);
    }

    .download-option {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      width: 100%;
      padding: 0.5rem 1rem;
      font-family: var(--font-body);
      font-size: 0.85rem;
      color: var(--body-text);
      background: none;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: background-color 0.15s ease;
    }

    .download-option:hover {
      background-color: var(--dark-bg);
    }

    [data-theme="dark"] .download-option:hover {
      background-color: rgba(255,255,255,0.08);
    }

    .download-option svg {
      flex-shrink: 0;
      width: 18px;
      height: 18px;
    }

    /* ===== Download Button ===== */
    .download-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 38px;
      height: 38px;
      padding: 0;
      color: var(--page-bg);
      background-color: var(--secondary);
      border: 2px solid var(--secondary);
      border-radius: 50%;
      text-decoration: none;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .download-btn svg {
      width: 15px;
      height: 15px;
    }

    .download-btn:hover {
      background-color: var(--tertiary);
      border-color: var(--tertiary);
      color: var(--page-bg);
    }

    [data-theme="dark"] .download-btn {
      color: #2d2927;
      background-color: var(--quaternary);
      border-color: var(--quaternary);
    }

    [data-theme="dark"] .download-btn:hover {
      background-color: var(--primary);
      border-color: var(--primary);
    }

    /* ===== Contributors ===== */
    .contributors-section {
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 1px solid var(--dark-bg);
    }

    .contributors-section .section-title {
      margin-bottom: 2rem;
    }

    .contributor {
      margin-bottom: 2rem;
    }

    .contributor-name {
      font-family: var(--font-headline);
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--body-text);
      margin-bottom: 0.25rem;
    }

    .contributor-bio {
      font-size: 0.95rem;
      color: var(--light-text);
      line-height: 1.65;
    }

    .essay-author a {
      color: inherit;
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color 0.2s ease;
    }

    .essay-author a:hover {
      border-bottom-color: var(--light-text);
    }

    /* ===== Footer ===== */
    .site-footer {
      text-align: center;
      padding: 3rem 0 2rem;
      font-family: var(--font-body);
      font-size: 0.85rem;
      color: var(--light-text);
    }

    /* ===== PDF / Print Mode ===== */
    body.print-mode .download-wrapper,
    body.print-mode .about-btn,
    body.print-mode .share-wrapper,
    body.print-mode .sidebar-actions,
    body.print-mode .top-bar,
    body.print-mode .sidebar,
    body.print-mode .sidebar-overlay,
    body.print-mode .progress-bar,
    body.print-mode .menu-toggle {
      display: none !important;
    }

    body.print-mode {
      background-color: #ffffff !important;
      color: #000000 !important;
      font-family: 'Times New Roman', 'Times', serif !important;
      font-size: 12pt !important;
      line-height: 1.6 !important;
    }

    body.print-mode .main-content {
      margin-left: 0;
      padding: 0;
      max-width: 100%;
    }

    body.print-mode .content-container {
      max-width: 100%;
    }

    /* Title page: centered, standalone */
    body.print-mode .hero {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      height: 100vh;
      page-break-after: always;
      margin-bottom: 0;
      padding-bottom: 0;
    }

    body.print-mode .hero-title {
      font-family: 'Times New Roman', 'Times', serif !important;
      font-size: 28pt !important;
      line-height: 1.2 !important;
      color: #000000 !important;
      margin-bottom: 0.5rem;
    }

    body.print-mode .hero-subtitle {
      font-family: 'Times New Roman', 'Times', serif !important;
      font-size: 14pt !important;
      font-style: italic;
      color: #000000 !important;
      margin-bottom: 2rem;
    }

    body.print-mode .hero-date {
      font-family: 'Times New Roman', 'Times', serif !important;
      font-size: 12pt !important;
      color: #333333 !important;
      margin-bottom: 1.5rem;
    }

    /* Add "Mere Orthodoxy" to title page via pseudo-element */
    body.print-mode .hero::before {
      content: "Mere Orthodoxy";
      font-family: 'Times New Roman', 'Times', serif;
      font-size: 14pt;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #333333;
      margin-bottom: 3rem;
    }

    /* Chapter headings: start on new page */
    body.print-mode .content-section {
      page-break-before: always;
      margin-bottom: 0;
    }

    body.print-mode .section-title {
      font-family: 'Times New Roman', 'Times', serif !important;
      font-size: 22pt !important;
      color: #000000 !important;
      border-top: 1px solid #000000;
      border-bottom: none;
      padding-top: 1.5rem;
      margin-top: 0;
      margin-bottom: 1.5rem;
    }

    body.print-mode .section-label {
      font-family: 'Times New Roman', 'Times', serif !important;
      font-size: 11pt !important;
      color: #333333 !important;
      margin-top: 0;
    }

    body.print-mode .section-heading {
      font-family: 'Times New Roman', 'Times', serif !important;
      font-size: 16pt !important;
      color: #000000 !important;
      margin-top: 2rem;
    }

    body.print-mode .subsection-heading {
      font-family: 'Times New Roman', 'Times', serif !important;
      font-size: 13pt !important;
      font-style: italic;
      color: #000000 !important;
    }

    body.print-mode .essay-heading {
      font-family: 'Times New Roman', 'Times', serif !important;
      font-size: 13pt !important;
      color: #000000 !important;
    }

    body.print-mode .essay-author {
      font-family: 'Times New Roman', 'Times', serif !important;
      font-size: 11pt !important;
      color: #333333 !important;
    }

    body.print-mode p {
      font-family: 'Times New Roman', 'Times', serif !important;
      font-size: 12pt !important;
      color: #000000 !important;
      line-height: 1.6 !important;
    }

    body.print-mode blockquote {
      font-family: 'Times New Roman', 'Times', serif !important;
      font-size: 11pt !important;
      color: #000000 !important;
