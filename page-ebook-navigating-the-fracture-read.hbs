  <!-- Scripts -->
  <script>
    // Print mode detection (for PDF generation)
    if (new URLSearchParams(window.location.search).get('print') === 'true') {
      document.body.classList.add('print-mode');
    }

    // Theme toggle
    const themeToggle = document.getElementById('themeToggle');
    const html = document.documentElement;

    themeToggle.addEventListener('click', () => {
      const current = html.getAttribute('data-theme');
      html.setAttribute('data-theme', current === 'dark' ? 'light' : 'dark');
    });

    // Sidebar toggle
    const menuToggle = document.getElementById('menuToggle');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebarOverlay');

    // Desktop: restore sidebar state
    if (window.innerWidth > 960) {
      if (localStorage.getItem('sidebarCollapsed') === 'true') {
        sidebar.classList.add('collapsed');
      }
    }

    // Hamburger handles both mobile and desktop
    menuToggle.addEventListener('click', () => {
      if (window.innerWidth <= 960) {
        // Mobile: slide-in overlay
        sidebar.classList.toggle('open');
        overlay.classList.toggle('open');
      } else {
        // Desktop: toggle collapsed
        if (sidebar.classList.contains('collapsed')) {
          sidebar.classList.remove('collapsed');
          localStorage.setItem('sidebarCollapsed', 'false');
        } else {
          sidebar.classList.add('collapsed');
          localStorage.setItem('sidebarCollapsed', 'true');
        }
      }
    });

    overlay.addEventListener('click', () => {
      sidebar.classList.remove('open');
      overlay.classList.remove('open');
    });

    // Close sidebar on link click (mobile)
    document.querySelectorAll('.toc-list a').forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth <= 960) {
          sidebar.classList.remove('open');
          overlay.classList.remove('open');
        }
      });
    });

    // Reading progress bar
    window.addEventListener('scroll', () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = (scrollTop / docHeight) * 100;
      document.getElementById('progressBar').style.width = progress + '%';
    });

    // Active TOC highlighting
    const contentSections = document.querySelectorAll('.content-section');
    const tocLinks = document.querySelectorAll('.toc-list a');

    const observerOptions = {
      rootMargin: '-10% 0px -80% 0px',
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          tocLinks.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('href') === '#' + id) {
              link.classList.add('active');
            }
          });
        }
      });
    }, observerOptions);

    contentSections.forEach(section => {
      observer.observe(section);
    });

    // Share functionality
    // {{SHARE_CONSTANTS}}: Update these for each ebook
    const SHARE_URL = window.location.origin + window.location.pathname;
    const SHARE_TITLE = 'Navigating the Fracture \u2014 Mere Orthodoxy';
    const SHARE_TEXT = 'Navigating the Fracture \u2014 Mere Orthodoxy';

    const shareToggle = document.getElementById('shareToggle');
    const sharePopup = document.getElementById('sharePopup');

    shareToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      sharePopup.classList.toggle('open');
      downloadPopup.classList.remove('open');
    });

    const downloadToggle = document.getElementById('downloadToggle');
    const downloadPopup = document.getElementById('downloadPopup');

    downloadToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      downloadPopup.classList.toggle('open');
      sharePopup.classList.remove('open');
    });

    document.addEventListener('click', (e) => {
      if (!sharePopup.contains(e.target) && e.target !== shareToggle) {
        sharePopup.classList.remove('open');
      }
      if (!downloadPopup.contains(e.target) && !downloadToggle.contains(e.target)) {
        downloadPopup.classList.remove('open');
      }
    });

    // Copy link
    document.getElementById('copyLink').addEventListener('click', () => {
      navigator.clipboard.writeText(SHARE_URL).then(() => {
        const msg = document.getElementById('copiedMsg');
        msg.classList.add('show');
        setTimeout(() => msg.classList.remove('show'), 2000);
      });
    });

    // Text message (sms: on mobile, fallback to sms: anyway)
    document.getElementById('shareSMS').href =
      'sms:?&body=' + encodeURIComponent(SHARE_TEXT + ' ' + SHARE_URL);

    // X (Twitter)
    document.getElementById('shareX').href =
      'https://x.com/intent/tweet?text=' + encodeURIComponent(SHARE_TEXT) +
      '&url=' + encodeURIComponent(SHARE_URL);

    // Facebook
    document.getElementById('shareFB').href =
      'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(SHARE_URL);

    // Instagram Stories (deep link — opens IG app with URL in clipboard)
    document.getElementById('shareIG').addEventListener('click', (e) => {
      e.preventDefault();
      navigator.clipboard.writeText(SHARE_URL).then(() => {
        window.open('https://www.instagram.com/create/story/', '_blank');
        const msg = document.getElementById('copiedMsg');
        msg.textContent = 'Link copied! Paste it in your Story.';
        msg.classList.add('show');
        setTimeout(() => { msg.classList.remove('show'); msg.textContent = 'Link copied!'; }, 4000);
      });
    });

    // ===== Highlight & Share =====
    const hsTooltip = document.getElementById('highlightShare');
    const hsCopiedMsg = document.getElementById('hsCopied');
    let selectedQuote = '';

    // Build share text with graceful attribution trimming for character limits.
    // {{ATTRIBUTION}}: Update the attribution strings below for each ebook.
    function buildShareText(rawQuote, limit) {
      const quote = rawQuote.replace(/\s+/g, ' ').trim();
      const wrapped = '\u201c' + quote + '\u201d';
      const attrFull = '\n\n\u2014 Navigating the Fracture, Mere Orthodoxy';
      const attrShort = '\n\n\u2014 Navigating the Fracture';
      const attrNone = '';

      if (!limit) return wrapped + attrFull;

      if ((wrapped + attrFull).length <= limit) return wrapped + attrFull;
      if ((wrapped + attrShort).length <= limit) return wrapped + attrShort;
      return wrapped + attrNone;
    }

    function positionTooltip(range) {
      const rect = range.getBoundingClientRect();
      const tooltipWidth = hsTooltip.offsetWidth || 200;
      const isMobile = window.innerWidth <= 960;
      const x = rect.left + rect.width / 2;
      const clampedX = Math.max(tooltipWidth / 2 + 8, Math.min(x, window.innerWidth - tooltipWidth / 2 - 8));
      hsTooltip.style.left = clampedX + 'px';
      if (isMobile) {
        // Below selection on mobile so it doesn't cover text
        hsTooltip.style.top = (rect.bottom + window.scrollY + 10) + 'px';
      } else {
        // Above selection on desktop
        hsTooltip.style.top = (rect.top + window.scrollY - 10) + 'px';
      }
    }

    function hideTooltip() {
      hsTooltip.classList.remove('visible');
      selectedQuote = '';
    }

    function checkSelection() {
      const sel = window.getSelection();
      const text = sel ? sel.toString().trim() : '';
      if (text.length > 3 && sel.rangeCount > 0 && document.querySelector('.main-content').contains(sel.anchorNode)) {
        selectedQuote = text;
        positionTooltip(sel.getRangeAt(0));
        hsTooltip.classList.add('visible');
      } else {
        hideTooltip();
      }
    }

    // Desktop: mouseup
    document.addEventListener('mouseup', (e) => {
      if (hsTooltip.contains(e.target)) return;
      setTimeout(checkSelection, 10);
    });

    document.addEventListener('mousedown', (e) => {
      if (!hsTooltip.contains(e.target)) {
        hideTooltip();
      }
    });

    // Mobile: selectionchange fires as the user adjusts selection handles
    let selectionChangeTimer = null;
    document.addEventListener('selectionchange', () => {
      if (!('ontouchstart' in window)) return; // only run on touch devices
      clearTimeout(selectionChangeTimer);
      selectionChangeTimer = setTimeout(checkSelection, 300);
    });

    // Copy quote + link (no limit)
    document.getElementById('hsCopy').addEventListener('click', () => {
      const text = buildShareText(selectedQuote, 0) + '\n\n' + SHARE_URL;
      navigator.clipboard.writeText(text).then(() => {
        hsCopiedMsg.classList.add('show');
        setTimeout(() => hsCopiedMsg.classList.remove('show'), 1500);
      });
    });

    // SMS with quote (no hard limit)
    document.getElementById('hsSMS').addEventListener('click', () => {
      const text = buildShareText(selectedQuote, 0) + '\n\n' + SHARE_URL;
      window.open('sms:?&body=' + encodeURIComponent(text));
    });

    // X with quote (~250 chars for text, URL takes ~30 via t.co)
    document.getElementById('hsX').addEventListener('click', () => {
      const text = buildShareText(selectedQuote, 250);
      window.open('https://x.com/intent/tweet?text=' + encodeURIComponent(text) + '&url=' + encodeURIComponent(SHARE_URL), '_blank');
    });

    // Facebook (no hard limit for quote param)
    document.getElementById('hsFB').addEventListener('click', () => {
      const text = buildShareText(selectedQuote, 0);
      window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(SHARE_URL) + '&quote=' + encodeURIComponent(text), '_blank');
    });

    // Instagram Stories (no limit — clipboard)
    document.getElementById('hsIG').addEventListener('click', () => {
      const text = buildShareText(selectedQuote, 0) + '\n\n' + SHARE_URL;
      navigator.clipboard.writeText(text).then(() => {
        window.open('https://www.instagram.com/create/story/', '_blank');
        hsCopiedMsg.textContent = 'Quote + link copied! Paste in your Story.';
        hsCopiedMsg.classList.add('show');
        setTimeout(() => { hsCopiedMsg.classList.remove('show'); hsCopiedMsg.textContent = 'Copied!'; }, 4000);
      });
    });
  </script>
