{{!< default}}
{{!-- /dashboard/replays/ — paid-only video replay library for past
     events. Gating mirrors other dashboard pages. --}}

<main class="dashboard">

  {{#unless @member}}
    <section class="hero dashboard-hero">
      <div class="container">
        <p class="hero-kicker"><span class="dot"></span> Member Dashboard</p>
        <h1 class="hero-headline">Sign in to watch the <span class="highlight"><em>replays</em></span>.</h1>
        <p class="dashboard-actions">
          <a href="#/portal/signin" class="btn btn-primary" data-portal="signin">Sign in</a>
          <a href="/membership/" class="btn btn-ghost">Become a Member</a>
        </p>
      </div>
    </section>
  {{else}}

    {{#match @member.status "paid"}}{{> "dashboard-replays-body"}}{{else}}
    {{#match @member.status "comped"}}{{> "dashboard-replays-body"}}{{else}}
    {{#match @member.email @custom.dashboard_preview_email}}
      <div class="dashboard-admin-banner" role="note">
        <strong>Admin preview.</strong> You are not a paid Member — this page is visible because your email matches <code>@custom.dashboard_preview_email</code>.
      </div>
      {{> "dashboard-replays-body"}}
    {{else}}
      <section class="hero dashboard-hero">
        <div class="container">
          <p class="hero-kicker"><span class="dot"></span> Member Dashboard</p>
          <h1 class="hero-headline">Replays are a <span class="highlight"><em>member feature</em></span>.</h1>
          <p>Become a Member to watch every past event on demand — plus ebooks, the quarterly journal, the full archive, and audio on every essay.</p>
          <p class="dashboard-actions"><a href="/membership/" class="btn btn-primary">Become a Member</a></p>
        </div>
      </section>
    {{/match}}
    {{/match}}
    {{/match}}

  {{/unless}}

</main>

<script src="{{asset "js/dashboard-replays.js"}}"></script>
