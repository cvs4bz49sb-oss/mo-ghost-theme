{{!< default}}
{{!-- custom-contributors: Directory of everyone who writes for Mere Orthodoxy.
     Pulls every public tag whose slug starts with "author-" so adding a
     contributor is a matter of creating the tag in Ghost admin
     (name + description + feature image). Wired to /contributors/ in
     routes.yaml. --}}

<main class="contributors">
  <section class="contributors-hero">
    <div class="container">
      <p class="eyebrow">The Writers</p>
      <h1 class="contributors-title"><em>Contributors</em></h1>
      <p class="contributors-sub">The people whose essays, reviews, and criticism make up <em>Mere&nbsp;Orthodoxy</em>.</p>
    </div>
  </section>

  <section class="contributors-body">
    <div class="container">
      {{!-- Fetch all public tags; CSS hides any whose slug isn't
           "author-…". Ghost's NQL `~^` prefix match on `slug` hasn't
           been reliable across Ghost versions, so the theme uses the
           same data-tag-slug attribute-selector pattern that drives
           contributor bylines and topic eyebrows. --}}
      <div class="contributors-grid">
        {{!-- limit=200 covers MO's contributor roster with headroom.
             Ghost's `limit="all"` on the tags endpoint has historically
             truncated at the default page size (~15) on this version,
             cutting the list off mid-alphabet. --}}
        {{#get "tags" filter="visibility:public" order="name asc" limit="200" include="count.posts"}}
          {{#foreach tags}}
            {{#if count.posts}}
              <a href="{{url}}" class="contributor-card contributor-card--candidate" data-tag-slug="{{slug}}">
                <div class="contributor-card-portrait" aria-hidden="true">
                  {{#if feature_image}}
                    <img src="{{img_url feature_image size="s"}}" alt="{{name}}" />
                  {{else}}
                    <span class="contributor-card-initial">{{name}}</span>
                  {{/if}}
                </div>
                <div class="contributor-card-body">
                  <h2 class="contributor-card-name"><em>{{name}}</em></h2>
                  {{#if description}}
                    <p class="contributor-card-bio">{{description}}</p>
                  {{/if}}
                  <p class="contributor-card-count">
                    {{count.posts}}
                    {{#match count.posts "=" 1}}essay{{else}}essays{{/match}}
                  </p>
                </div>
              </a>
            {{/if}}
          {{/foreach}}
        {{/get}}
      </div>
    </div>
  </section>
</main>
