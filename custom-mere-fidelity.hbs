{{!< default}}
{{!-- /podcasts/mere-fidelity/ — routed via routes.yaml.
     Hero: header left, artwork right. Body: episode feed left
     (rendered by podcast-feed.js with data-show filter), host
     list right (pulled from each host's author-* contributor tag
     so bios + headshots stay in one place). --}}

<main class="podcast-page">

  <section class="hero podcast-hero">
    <div class="container">
      <div class="podcast-hero-grid">
        <div class="podcast-hero-content">
          <p class="hero-kicker"><span class="dot"></span> Podcast</p>
          <h1 class="podcast-hero-headline">Thinking deeply about <span class="highlight"><em>the Word of God</em></span> and the world we live in.</h1>
          <p class="podcast-hero-sub"><em>Mere Fidelity</em> reflects on God's Word and our world. Thoughtful weekly conversations on theology, the culture, and the church.</p>
          <div class="podcast-hero-ctas">
            {{#if @custom.podcast_mf_apple_url}}<a href="{{@custom.podcast_mf_apple_url}}" class="btn btn-primary btn-lg" target="_blank" rel="noopener">Apple Podcasts</a>{{/if}}
            {{#if @custom.podcast_mf_spotify_url}}<a href="{{@custom.podcast_mf_spotify_url}}" class="btn btn-ghost btn-lg" target="_blank" rel="noopener">Spotify</a>{{/if}}
          </div>
        </div>
        <div class="podcast-hero-art" aria-hidden="true">
          <img src="{{asset "images/mere-fidelity.jpg"}}" alt="Mere Fidelity" />
        </div>
      </div>
    </div>
  </section>

  <section class="podcast-body">
    <div class="container">
      <div class="podcast-grid">

        <div class="podcast-episodes">
          <div class="section-intro section-intro-left">
            <p class="eyebrow">Latest Episodes</p>
            <h2 class="section-heading"><em>Listen now.</em></h2>
          </div>
          <div class="listen-grid podcast-episode-list"
               data-show="mere-fidelity"
               data-show-limit="8"
               data-mf-apple="{{@custom.podcast_mf_apple_url}}"
               data-mf-spotify="{{@custom.podcast_mf_spotify_url}}"
               data-crc-apple="{{@custom.podcast_crc_apple_url}}"
               data-crc-spotify="{{@custom.podcast_crc_spotify_url}}">
            <p class="podcast-episodes-loading">Loading episodes&hellip;</p>
          </div>
        </div>

        <aside class="podcast-hosts">
          <div class="section-intro section-intro-left">
            <p class="eyebrow">The Hosts</p>
            <h2 class="section-heading"><em>Who you'll hear.</em></h2>
          </div>
          <ul class="podcast-host-list">
            {{#get "tags" filter="slug:author-derek-rishmawy" limit="1"}}{{#foreach tags}}
              <li class="podcast-host"><a href="{{url}}" class="podcast-host-link"><div class="podcast-host-portrait" aria-hidden="true">{{#if feature_image}}<img src="{{img_url feature_image size="s"}}" alt="{{name}}" />{{else}}<span class="podcast-host-initial">{{name}}</span>{{/if}}</div><h3 class="podcast-host-name"><em>{{name}}</em></h3></a></li>
            {{/foreach}}{{/get}}
            {{#get "tags" filter="slug:author-alastair-roberts" limit="1"}}{{#foreach tags}}
              <li class="podcast-host"><a href="{{url}}" class="podcast-host-link"><div class="podcast-host-portrait" aria-hidden="true">{{#if feature_image}}<img src="{{img_url feature_image size="s"}}" alt="{{name}}" />{{else}}<span class="podcast-host-initial">{{name}}</span>{{/if}}</div><h3 class="podcast-host-name"><em>{{name}}</em></h3></a></li>
            {{/foreach}}{{/get}}
            {{#get "tags" filter="slug:author-andrew-wilson" limit="1"}}{{#foreach tags}}
              <li class="podcast-host"><a href="{{url}}" class="podcast-host-link"><div class="podcast-host-portrait" aria-hidden="true">{{#if feature_image}}<img src="{{img_url feature_image size="s"}}" alt="{{name}}" />{{else}}<span class="podcast-host-initial">{{name}}</span>{{/if}}</div><h3 class="podcast-host-name"><em>{{name}}</em></h3></a></li>
            {{/foreach}}{{/get}}
            {{#get "tags" filter="slug:author-brad-east" limit="1"}}{{#foreach tags}}
              <li class="podcast-host"><a href="{{url}}" class="podcast-host-link"><div class="podcast-host-portrait" aria-hidden="true">{{#if feature_image}}<img src="{{img_url feature_image size="s"}}" alt="{{name}}" />{{else}}<span class="podcast-host-initial">{{name}}</span>{{/if}}</div><h3 class="podcast-host-name"><em>{{name}}</em></h3></a></li>
            {{/foreach}}{{/get}}
            {{#get "tags" filter="slug:author-james-wood" limit="1"}}{{#foreach tags}}
              <li class="podcast-host"><a href="{{url}}" class="podcast-host-link"><div class="podcast-host-portrait" aria-hidden="true">{{#if feature_image}}<img src="{{img_url feature_image size="s"}}" alt="{{name}}" />{{else}}<span class="podcast-host-initial">{{name}}</span>{{/if}}</div><h3 class="podcast-host-name"><em>{{name}}</em></h3></a></li>
            {{/foreach}}{{/get}}
            {{#get "tags" filter="slug:author-joseph-minich" limit="1"}}{{#foreach tags}}
              <li class="podcast-host"><a href="{{url}}" class="podcast-host-link"><div class="podcast-host-portrait" aria-hidden="true">{{#if feature_image}}<img src="{{img_url feature_image size="s"}}" alt="{{name}}" />{{else}}<span class="podcast-host-initial">{{name}}</span>{{/if}}</div><h3 class="podcast-host-name"><em>{{name}}</em></h3></a></li>
            {{/foreach}}{{/get}}
          </ul>
        </aside>

      </div>
    </div>
  </section>

</main>

<script src="{{asset "js/podcast-feed.js"}}"></script>
