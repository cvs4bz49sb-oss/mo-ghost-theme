{{!< default}}
{{!-- /events/ — library view listing every #event post, split into
     "Upcoming" (no replay embed yet) and "Past Events" (replay
     embed present in the post body). The actual event detail with
     title, body, and registration form lives at /forum/ or at each
     event's own post URL. --}}

<main class="events-page">

  <div data-events-source hidden>
    {{#get "posts" filter="tag:hash-event" order="published_at desc" limit="all"}}
      {{#foreach posts}}
        <article class="events-item"
                 data-slug="{{slug}}"
                 data-url="{{url}}"
                 data-title="{{title}}"
                 data-excerpt="{{custom_excerpt}}"
                 data-feature-image="{{#if feature_image}}{{img_url feature_image size="xl"}}{{/if}}"
                 data-published-at="{{published_at}}">
          <div class="events-item-content">{{content}}</div>
        </article>
      {{/foreach}}
    {{/get}}
  </div>

  <section class="hero events-library-hero">
    <div class="container">
      <p class="hero-kicker"><span class="dot"></span> Online Events</p>
      <h1 class="hero-headline">Gather in <span class="highlight"><em>community</em></span>.</h1>
      <p class="hero-sub">Online gatherings with editors, contributors, and leading thinkers on theology, culture, and faithful public witness. Register for what's next; revisit every past event in the library.</p>
    </div>
  </section>

  <section class="events-library-body">
    <div class="container container-narrow">

      <div class="events-library-section" data-events-library-upcoming hidden>
        <p class="eyebrow">Upcoming</p>
        <h2 class="events-library-title"><em>What's next.</em></h2>
        <ol class="events-library-list" data-events-library-upcoming-list></ol>
      </div>

      <div class="flourish">{{> "flourish-mark"}}</div>

      <div class="events-library-section" data-events-library-past hidden>
        <p class="eyebrow">Past Events</p>
        <h2 class="events-library-title"><em>The archive.</em></h2>
        <p class="events-library-sub">Paid Members can watch every replay in <a href="/dashboard/replays/">the replay library</a>.</p>
        <ol class="events-library-list" data-events-library-past-list></ol>
      </div>

      <div class="events-library-empty" data-events-empty hidden>
        <p class="eyebrow">Coming Soon</p>
        <h2 class="events-library-title"><em>No events on the calendar yet.</em></h2>
        <p>Subscribe to {{@site.title}} to be first to hear when the next online event goes live.</p>
      </div>

    </div>
  </section>

</main>

<script src="{{asset "js/events.js"}}"></script>
