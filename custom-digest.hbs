{{!< default}}
{{!-- custom-digest: internal tool page that wraps the mo-digest
     Cloudflare Worker in Mere Orthodoxy chrome. The page collects a
     date window + auth token, POSTs JSON to the worker, and displays
     the returned draft with a rich-text copy button. Matches the
     about-page hero treatment so the tool feels part of the site.

     Worker URL comes from @custom.digest_worker_url so staging and
     production can point at different workers if needed. Route is
     /digest/ via routes.yaml. --}}

<main class="about digest-page">

  <section class="hero about-hero">
    <div class="container">
      <div class="about-hero-grid">
        <div class="about-hero-content">
          <p class="hero-kicker"><span class="dot"></span> Editor Tools</p>
          <h1 class="hero-headline about-hero-headline">
            The Weekly <span class="highlight about-hero-highlight"><em>Digest</em></span> generator.
          </h1>
          <p class="hero-sub">Pull the last week's essays and podcast episodes, run them through Claude with the Mere Orthodoxy editorial guidelines, and hand back a draft ready to paste into Kit. You'll still edit it.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="about-body">
    <div class="container container-narrow">

      <div class="about-prose">
        <div class="digest-controls">
          <div class="digest-field">
            <label for="digest-days">Window (days)</label>
            <input id="digest-days" type="number" min="1" max="30" value="7">
          </div>
          {{!-- Auth field is visually hidden when @custom.digest_auth_token
               is set; the JS still reads it, just pre-filled. If the
               admin setting is empty, the field surfaces so you can
               paste a token manually. --}}
          <div class="digest-field digest-field--grow{{#if @custom.digest_auth_token}} digest-field--hidden{{/if}}">
            <label for="digest-token">Auth token</label>
            <input id="digest-token" type="password" autocomplete="current-password" placeholder="Paste your DIGEST_AUTH_TOKEN">
          </div>
          <div class="digest-field digest-field--action">
            <button id="digest-generate" class="btn btn-primary btn-lg" type="button">Generate draft</button>
          </div>
        </div>
        <p class="digest-status" id="digest-status" aria-live="polite"></p>
      </div>

      <div class="digest-output" id="digest-output-wrap" hidden>
        <div class="flourish"><span class="flourish-mark">&para;</span></div>

        <div class="section-intro">
          <p class="eyebrow">The Draft</p>
          <h2 class="section-heading"><em>This week's digest.</em></h2>
        </div>

        <textarea id="digest-output" spellcheck="false" aria-label="Generated digest draft"></textarea>

        <div class="digest-actions">
          <button class="btn btn-primary" id="digest-copy" type="button">Copy for Kit / HubSpot</button>
          <button class="btn btn-outline" id="digest-download" type="button">Download .md</button>
        </div>
        <p class="digest-meta" id="digest-meta"></p>
      </div>

    </div>
  </section>
</main>

<script>
(function () {
  var WORKER = {{#if @custom.digest_worker_url}}"{{@custom.digest_worker_url}}"{{else}}""{{/if}};
  var PREFILL_TOKEN = {{#if @custom.digest_auth_token}}"{{@custom.digest_auth_token}}"{{else}}""{{/if}};
  var STORAGE = "mo_digest_token";

  var tokenInput = document.getElementById("digest-token");
  var daysInput = document.getElementById("digest-days");
  var generate = document.getElementById("digest-generate");
  var status = document.getElementById("digest-status");
  var outputWrap = document.getElementById("digest-output-wrap");
  var output = document.getElementById("digest-output");
  var meta = document.getElementById("digest-meta");
  var copy = document.getElementById("digest-copy");
  var download = document.getElementById("digest-download");

  if (!WORKER) {
    setStatus("Set @custom.digest_worker_url in Ghost admin (Design → Customize) to the mo-digest worker URL.", true);
    generate.disabled = true;
    return;
  }

  // Preference: admin-injected token > localStorage > empty.
  try {
    var stored = localStorage.getItem(STORAGE) || "";
    tokenInput.value = PREFILL_TOKEN || stored;
    if (PREFILL_TOKEN) { try { localStorage.setItem(STORAGE, PREFILL_TOKEN); } catch (_) {} }
  } catch (_) {
    tokenInput.value = PREFILL_TOKEN || "";
  }
  tokenInput.addEventListener("input", function () {
    tokenInput.value = tokenInput.value.replace(/[^\x20-\x7E]/g, "");
    try { localStorage.setItem(STORAGE, tokenInput.value); } catch (_) {}
  });

  generate.addEventListener("click", function () {
    var token = tokenInput.value.trim();
    if (!token) { setStatus("Enter the auth token first.", true); return; }
    var days = parseInt(daysInput.value, 10) || 7;
    try { localStorage.setItem(STORAGE, token); } catch (_) {}

    generate.disabled = true;
    setStatus("Fetching posts and asking Claude… this takes 15–30 seconds.");
    outputWrap.hidden = true;

    fetch(WORKER.replace(/\/$/, "") + "/generate", {
      method: "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify({ days: days, token: token }),
    })
      .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, body: j }; }); })
      .then(function (res) {
        if (!res.ok || res.body.error) throw new Error(res.body.error || "Request failed");
        output.value = res.body.draft || "";
        outputWrap.hidden = false;
        var m = res.body.meta || {};
        meta.textContent = (m.articleCount || 0) + " articles, " + (m.podcastCount || 0) + " podcasts since " + (m.since || "").slice(0, 10) + " · " + (m.model || "");
        var warns = (res.body.warnings || []).join(" · ");
        setStatus(warns ? "Done. " + warns : "Done.");
        outputWrap.scrollIntoView({ behavior: "smooth", block: "start" });
      })
      .catch(function (err) { setStatus(err.message || String(err), true); })
      .then(function () { generate.disabled = false; });
  });

  copy.addEventListener("click", function () {
    var md = output.value;
    var html = mdToHtml(md);
    var done = function () { setStatus("Copied. Paste into Kit or HubSpot and it'll render formatted."); };
    var plain = function () {
      try { navigator.clipboard.writeText(md).then(done); }
      catch (_) { output.select(); document.execCommand("copy"); done(); }
    };
    try {
      if (window.ClipboardItem && navigator.clipboard && navigator.clipboard.write) {
        var item = new ClipboardItem({
          "text/html": new Blob([html], { type: "text/html" }),
          "text/plain": new Blob([md], { type: "text/plain" }),
        });
        navigator.clipboard.write([item]).then(done).catch(plain);
      } else {
        plain();
      }
    } catch (_) { plain(); }
  });

  download.addEventListener("click", function () {
    var blob = new Blob([output.value], { type: "text/markdown" });
    var a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = "mo-digest-" + new Date().toISOString().slice(0, 10) + ".md";
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(a.href);
  });

  function setStatus(msg, isError) {
    status.textContent = msg;
    status.classList.toggle("is-error", !!isError);
  }

  function mdToHtml(md) {
    var out = [];
    String(md || "").split(/\n{2,}/).forEach(function (block) {
      var b = block.trim();
      if (!b) return;
      if (/^---+$/.test(b)) { out.push("<hr>"); return; }
      if (/^### /.test(b)) { out.push("<h3>" + inline(b.slice(4)) + "</h3>"); return; }
      if (/^## /.test(b))  { out.push("<h2>" + inline(b.slice(3)) + "</h2>"); return; }
      if (/^# /.test(b))   { out.push("<h1>" + inline(b.slice(2)) + "</h1>"); return; }
      var lines = b.split(/\n/);
      if (lines.every(function (l) { return /^\d+\.\s+/.test(l); })) {
        out.push("<ol>" + lines.map(function (l) { return "<li>" + inline(l.replace(/^\d+\.\s+/, "")) + "</li>"; }).join("") + "</ol>");
        return;
      }
      if (lines.every(function (l) { return /^-\s+/.test(l); })) {
        out.push("<ul>" + lines.map(function (l) { return "<li>" + inline(l.replace(/^-\s+/, "")) + "</li>"; }).join("") + "</ul>");
        return;
      }
      // Escape first (inline escapes <>&), THEN substitute newlines
      // for real <br> so they survive the escape pass.
      out.push("<p>" + inline(b).replace(/\n/g, "<br>") + "</p>");
    });
    return out.join("\n");
  }
  function inline(s) {
    var t = String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    t = t.replace(/\[([^\]]+)\]\(([^)]+)\)/g, function (_, text, href) {
      return '<a href="' + href.replace(/"/g, "&quot;") + '">' + text + "</a>";
    });
    t = t.replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");
    t = t.replace(/\*([^*]+)\*/g, "<em>$1</em>");
    t = t.replace(/_([^_]+)_/g, "<em>$1</em>");
    return t;
  }
})();
</script>
