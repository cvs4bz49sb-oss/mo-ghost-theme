{{!< default}}
{{!-- /submissions/ — routed via routes.yaml. Same editorial pattern
     as /contact/ and /about/. --}}

<main class="about contact-page">

  <section class="hero about-hero contact-page-hero">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">Submissions</p>
        <h1 class="section-heading contact-page-headline">Write for <em><span class="highlight">Mere&nbsp;Orthodoxy</span>.</em></h1>
        <p class="contact-page-sub">We are always accepting essay submissions. Long-form, serious, theologically honest.</p>
      </div>
    </div>
  </section>

  <section class="about-body">
    <div class="container container-narrow">

      <div class="section-intro">
        <p class="eyebrow">Guidelines</p>
        <h2 class="section-heading"><em>Before you submit.</em></h2>
      </div>
      <ol class="submissions-guidelines">
        <li class="submissions-guideline">
          <span class="submissions-guideline-numeral">I</span>
          <div>
            <h3 class="submissions-guideline-label"><em>Format</em></h3>
            <p>Submit as a .docx file using the form below.</p>
          </div>
        </li>
        <li class="submissions-guideline">
          <span class="submissions-guideline-numeral">II</span>
          <div>
            <h3 class="submissions-guideline-label"><em>Links, not footnotes</em></h3>
            <p>Use hyperlinks rather than footnotes.</p>
          </div>
        </li>
        <li class="submissions-guideline">
          <span class="submissions-guideline-numeral">III</span>
          <div>
            <h3 class="submissions-guideline-label"><em>Patience</em></h3>
            <p>Allow up to two weeks for a reply before asking for an update. If the submission is time-sensitive, note that in the subject line and we'll do our best to review it sooner.</p>
          </div>
        </li>
      </ol>

      <div class="flourish">{{> "flourish-mark"}}</div>

      <div class="section-intro">
        <p class="eyebrow">AI Policy</p>
        <h2 class="section-heading"><em>Written by a human.</em></h2>
      </div>
      <div class="about-prose">
        <p>All article text must be written by a human. We follow <a href="https://thedispatch.com/ai-policy/" target="_blank" rel="noopener"><em>The Dispatch</em>'s AI policy</a>.</p>
      </div>

      <div class="flourish">{{> "flourish-mark"}}</div>

      <div class="section-intro">
        <p class="eyebrow">Submit</p>
        <h2 class="section-heading"><em>Tell us about your piece.</em></h2>
      </div>

      <form class="site-form site-form-narrow" data-site-form="submissions" data-worker-url="{{@custom.forms_worker_url}}" enctype="multipart/form-data" novalidate>
        <div class="site-form-row">
          <div class="site-form-field">
            <label for="sub-first">First name</label>
            <input id="sub-first" name="firstName" type="text" autocomplete="given-name" required />
          </div>
          <div class="site-form-field">
            <label for="sub-last">Last name</label>
            <input id="sub-last" name="lastName" type="text" autocomplete="family-name" required />
          </div>
        </div>
        <div class="site-form-field">
          <label for="sub-email">Email</label>
          <input id="sub-email" name="email" type="email" autocomplete="email" required />
        </div>
        <div class="site-form-field">
          <label for="sub-phone">Phone</label>
          <input id="sub-phone" name="phone" type="tel" autocomplete="tel" required />
        </div>
        <div class="site-form-field">
          <label for="sub-bio">Author bio</label>
          <p class="site-form-note">150 characters max.</p>
          <textarea id="sub-bio" name="bio" rows="3" maxlength="150" required></textarea>
        </div>

        <div class="site-form-field">
          <label>Essay</label>
          <p class="site-form-note">.docx, 20 MB max.</p>
          <label class="site-form-upload" data-upload>
            <input id="sub-essay" name="essay" type="file" accept=".docx,application/vnd.openxmlformats-officedocument.wordprocessingml.document" required />
            <span class="site-form-upload-btn">Choose file</span>
            <span class="site-form-upload-name" data-upload-name>No file chosen</span>
          </label>
        </div>

        <div class="site-form-field">
          <label>Author headshot</label>
          <p class="site-form-note">Square image preferred, 20 MB max.</p>
          <label class="site-form-upload" data-upload>
            <input id="sub-headshot" name="headshot" type="file" accept="image/*" required />
            <span class="site-form-upload-btn">Choose image</span>
            <span class="site-form-upload-name" data-upload-name>No file chosen</span>
          </label>
        </div>

        <div class="site-form-field site-form-field-check">
          <label>
            <input name="aiAttested" type="checkbox" value="true" required />
            <span>I wrote this piece myself and abided by the AI policy.</span>
          </label>
        </div>

        <button type="submit" class="site-form-submit">Submit</button>
        <p class="site-form-status" data-form-status></p>
      </form>

    </div>
  </section>

</main>

<script src="{{asset "js/site-forms.js"}}"></script>
