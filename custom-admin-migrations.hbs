{{!< default}}
{{!-- /admin/members/migrations/ — HubSpot members who've submitted
     a migration request via /migrate/. Each row is a record with
     name, email, "started new Membership" flag, and a workflow
     status (pending / cancelled / no_action). --}}

<main class="admin-page">
  {{#if @member}}

    <section class="hero admin-hero">
      <div class="container">
        <p class="hero-kicker"><span class="dot"></span> Admin &middot; Members</p>
        <h1 class="admin-headline">Migration <em><span class="highlight">requests</span></em>.</h1>
        <p class="admin-sub">HubSpot members who've asked to move their Membership over. Look each one up in HubSpot, cancel them there, then mark the row Cancelled.</p>
      </div>
    </section>

    {{> "admin-nav"}}

    <section class="admin-body">
      <div class="container">
        <div class="admin-members-layout">
          <aside class="admin-members-sidebar">
            {{> "admin-members-subnav" active="migrations"}}
          </aside>
          <div class="admin-members-main">
            <div class="admin-migrations-host"
                 data-migrations
                 data-api-base="{{@custom.membership_api_base}}"
                 data-member-email="{{@member.email}}">

              <ul class="admin-stats" data-migrations-stats>
                <li class="admin-stat"><span class="admin-stat-label">Pending</span><span class="admin-stat-value" data-stat="pending">&mdash;</span></li>
                <li class="admin-stat"><span class="admin-stat-label">Cancelled</span><span class="admin-stat-value" data-stat="cancelled">&mdash;</span></li>
                <li class="admin-stat"><span class="admin-stat-label">No action</span><span class="admin-stat-value" data-stat="no_action">&mdash;</span></li>
                <li class="admin-stat"><span class="admin-stat-label">Total</span><span class="admin-stat-value" data-stat="total">&mdash;</span></li>
              </ul>

              <p class="admin-table-status" data-migrations-status>Loading migration requests&hellip;</p>

              <div class="admin-table-wrap">
                <table class="admin-table admin-migrations-table" data-migrations-table hidden>
                  <thead>
                    <tr>
                      <th>Name</th>
                      <th>Email</th>
                      <th>Started new</th>
                      <th>Status</th>
                      <th>Submitted</th>
                      <th aria-label="Actions"></th>
                    </tr>
                  </thead>
                  <tbody data-migrations-tbody></tbody>
                </table>
              </div>

              <p class="admin-migrations-empty" data-migrations-empty hidden>
                No migration requests yet.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

  {{else}}
    {{> "admin-denied"}}
  {{/if}}
</main>

<script src="{{asset "js/admin-auth.js"}}"></script>
<script src="{{asset "js/admin-migrations.js"}}"></script>
