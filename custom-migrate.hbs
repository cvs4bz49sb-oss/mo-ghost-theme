{{!< default}}
{{!-- /migrate/ — three-step page for current HubSpot members
     moving their Membership over to the Ghost site. Linked from
     a one-off migration email; not surfaced in nav. Step 2 sends
     them back to the legacy mereorthodoxy.com cancel form, where
     Ian processes the cancellation manually. --}}

<main class="membership membership-support migrate-page">

  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Membership Migration</p>
      <h1 class="page-hero-headline"><em>Move your Membership</em> to the new site.</h1>
      <p class="page-hero-sub">
        Mere&nbsp;Orthodoxy is moving off our old platform. Three steps will bring your Membership over. You won't lose access during the move &mdash; if anything overlaps, email <a href="mailto:ian@mereorthodoxy.com">ian@mereorthodoxy.com</a> and we'll sort it out.
      </p>
    </div>
  </section>

  <section class="migrate-steps">
    <div class="container">
      <ol class="migrate-list">

        <li class="migrate-step">
          <div class="migrate-step-numeral">I.</div>
          <div class="migrate-step-body">
            <p class="eyebrow">Step One</p>
            <h2 class="migrate-step-label"><em>Start your new Membership.</em></h2>
            <p class="migrate-step-text">
              Sign up here, on the new site. Pick the tier that fits &mdash; the print journal mailed to your door, the full archive, audio versions, and the ebook library all come with Membership. Use the same email you used on the old site so we can match your records.
            </p>
            <p class="migrate-step-cta">
              <a href="/membership/" class="btn btn-primary btn-inline">Become a Member</a>
            </p>
          </div>
        </li>

        <li class="migrate-step">
          <div class="migrate-step-numeral">II.</div>
          <div class="migrate-step-body">
            <p class="eyebrow">Step Two</p>
            <h2 class="migrate-step-label"><em>Cancel your old Membership.</em></h2>
            <p class="migrate-step-text">
              Submit a cancellation request through the form on the old site. Ian processes these by hand within a day or two, so your previous Membership won't keep billing once the new one is live. The link opens in a new tab.
            </p>
            <p class="migrate-step-cta">
              <a href="https://mereorthodoxy.com/manage-membership" class="btn btn-primary btn-inline" target="_blank" rel="noopener">Submit Cancellation Request</a>
            </p>
          </div>
        </li>

        <li class="migrate-step">
          <div class="migrate-step-numeral">III.</div>
          <div class="migrate-step-body">
            <p class="eyebrow">Step Three</p>
            <h2 class="migrate-step-label"><em>Manage from your dashboard.</em></h2>
            <p class="migrate-step-text">
              Once you're set up here, the Member Dashboard is where you'll handle billing, your mailing address, bookmarks, the ebook library, and reading history. You can update or cancel any time from there.
            </p>
            <p class="migrate-step-cta">
              <a href="/dashboard/" class="btn btn-primary btn-inline">Open Dashboard</a>
            </p>
          </div>
        </li>

      </ol>

      <p class="migrate-coda">
        <em>Questions during the move? Email <a href="mailto:ian@mereorthodoxy.com">ian@mereorthodoxy.com</a> and we'll get you sorted.</em>
      </p>
    </div>
  </section>

</main>
