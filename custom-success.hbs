{{!< default}}
{{!-- custom-success: Mere Orthodoxy post-checkout success page --}}

<main class="membership membership-support page-simple">

  <div class="centered-main">
    <div class="container centered-inner">
      <div class="check-icon" aria-hidden="true">
        <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
          <circle cx="32" cy="32" r="30" fill="none" stroke="currentColor" stroke-width="3" />
          <path d="M19 33 L28 42 L46 22" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
      <h1 class="page-hero-headline page-hero-headline--dark">Welcome to Mere&nbsp;Orthodoxy.</h1>
      <p class="page-hero-sub page-hero-sub--dark">
        Your membership is confirmed. You'll receive a welcome email shortly.
        If you signed up for a print journal subscription, your first issue
        will arrive when the next issue ships.
      </p>
      <div class="button-row">
        <a href="https://mereorthodoxy.com" class="btn btn-primary btn-inline">Read Mere&nbsp;Orthodoxy</a>
        <a href="/manage" class="btn btn-dark btn-inline">Manage Your Membership</a>
      </div>
      <p class="fine-print">Questions? Email us at <a href="mailto:ian@mereorthodoxy.com">ian@mereorthodoxy.com</a>.</p>
    </div>
  </div>

</main>
