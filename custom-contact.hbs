{{!< default}}
{{!-- /contact/ — routed via routes.yaml. Centered hero over a
     two-column body: editorial categories on the left, form
     pinned top-right. Aesthetic borrowed from /about/. --}}

<main class="contact-page">

  <section class="hero contact-page-hero">
    <div class="container">
      <p class="hero-kicker"><span class="dot"></span> Contact Mere&nbsp;Orthodoxy</p>
      <h1 class="contact-page-headline"><em>Want to <span class="highlight">talk?</span></em></h1>
      <p class="contact-page-sub">We're glad you're here. Drop us a line below, or use one of the categories to reach the right part of the team.</p>
    </div>
  </section>

  <section class="contact-page-body">
    <div class="container">
      <div class="contact-page-grid">

        <div class="contact-page-left">
          <div class="contact-section">
            <p class="eyebrow">General Questions</p>
            <p>Use the form to send any general questions or comments.</p>
          </div>
          <div class="flourish">{{> "flourish-mark"}}</div>

          <div class="contact-section">
            <p class="eyebrow">Donate</p>
            <p>To make a tax-deductible donation, <a href="/donate/">visit the donate page</a>.</p>
          </div>
          <div class="contact-section">
            <p class="eyebrow">Submissions</p>
            <p>If you want to write for us, <a href="/submissions/">submit an essay here</a>.</p>
          </div>
          <div class="contact-section">
            <p class="eyebrow">Advertise With Us</p>
            <p>Email <a href="mailto:ads@mereorthodoxy.com">ads@mereorthodoxy.com</a>.</p>
          </div>
          <div class="contact-section">
            <p class="eyebrow">Media &amp; Speaking Requests</p>
            <p>Email <a href="mailto:press@mereorthodoxy.com">press@mereorthodoxy.com</a>.</p>
          </div>
          <div class="contact-section">
            <p class="eyebrow">Manage Membership</p>
            <p><a href="/manage/">Update billing, address, or cancel</a>.</p>
          </div>

          <div class="flourish">{{> "flourish-mark"}}</div>

          <div class="contact-section">
            <p class="eyebrow">Reach Us By Mail</p>
            <address class="contact-address">
              Mere&nbsp;Orthodoxy<br />
              2040 South Street<br />
              Lincoln, NE 68502
            </address>
          </div>
        </div>

        <aside class="contact-page-right">
          <div class="contact-form-panel">
            <p class="eyebrow">Send a note</p>
            <h2 class="contact-panel-heading"><em>We'll get back to you.</em></h2>
            <form class="site-form" data-site-form="contact" data-worker-url="{{@custom.forms_worker_url}}" novalidate>
              <div class="site-form-row">
                <div class="site-form-field">
                  <label for="contact-first">First name</label>
                  <input id="contact-first" name="firstName" type="text" autocomplete="given-name" required />
                </div>
                <div class="site-form-field">
                  <label for="contact-last">Last name</label>
                  <input id="contact-last" name="lastName" type="text" autocomplete="family-name" required />
                </div>
              </div>
              <div class="site-form-field">
                <label for="contact-email">Email</label>
                <input id="contact-email" name="email" type="email" autocomplete="email" required />
              </div>
              <div class="site-form-field">
                <label for="contact-message">Message</label>
                <textarea id="contact-message" name="message" rows="5" required></textarea>
              </div>
              <button type="submit" class="site-form-submit">Send</button>
              <p class="site-form-status" data-form-status></p>
            </form>
          </div>
        </aside>

      </div>
    </div>
  </section>

</main>

<script src="{{asset "js/site-forms.js"}}"></script>
