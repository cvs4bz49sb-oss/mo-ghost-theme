{{!< default}}
{{!-- /contact/ — routed via routes.yaml. --}}

<section class="mb-hero contact-hero">
  <div class="container">
    <div class="section-intro section-intro-light">
      <p class="eyebrow eyebrow-light">Contact Mere&nbsp;Orthodoxy</p>
      <h1 class="mb-hero-headline"><em>Want to <span class="highlight">talk?</span></em></h1>
      <p class="mb-hero-sub">A few good ways to reach us. The form sends straight to the editors; the categories below route to the right team.</p>
    </div>
  </div>
</section>

<section class="contact-body">
  <div class="container contact-grid">

    <div class="contact-intro">
      <div class="contact-section">
        <p class="eyebrow">General Questions</p>
        <p>Complete the form if you have any general questions or comments.</p>
      </div>

      <div class="flourish">{{> "flourish-mark"}}</div>

      <div class="contact-section">
        <p class="eyebrow">Donate</p>
        <p>To make a tax-deductible donation, <a href="/donate/">visit the donate page</a>.</p>
      </div>

      <div class="contact-section">
        <p class="eyebrow">Submissions</p>
        <p>If you want to write for us, <a href="/submissions/">submit an essay here</a>.</p>
      </div>

      <div class="contact-section">
        <p class="eyebrow">Advertise With Us</p>
        <p>If you are interested in advertising with <em>Mere&nbsp;Orthodoxy</em>, email <a href="mailto:ads@mereorthodoxy.com">ads@mereorthodoxy.com</a>.</p>
      </div>

      <div class="contact-section">
        <p class="eyebrow">Media &amp; Speaking Requests</p>
        <p>Email <a href="mailto:press@mereorthodoxy.com">press@mereorthodoxy.com</a>.</p>
      </div>

      <div class="contact-section">
        <p class="eyebrow">Manage Membership</p>
        <p><a href="/manage/">Update your billing, address, or cancel</a>.</p>
      </div>

      <div class="flourish">{{> "flourish-mark"}}</div>

      <div class="contact-section">
        <p class="eyebrow">Reach Us By Mail</p>
        <address class="contact-address">
          Mere&nbsp;Orthodoxy<br />
          2040 South Street<br />
          Lincoln, NE 68502
        </address>
      </div>
    </div>

    <aside class="contact-form-wrap" aria-labelledby="contact-form-heading">
      <p class="eyebrow">Contact Us</p>
      <h2 id="contact-form-heading" class="contact-form-heading"><em>Send us a note.</em></h2>
      <p class="contact-form-sub">Fill out the form with any questions and we'll get back to you.</p>

      <form class="site-form" data-site-form="contact" data-worker-url="{{@custom.forms_worker_url}}" novalidate>
        <div class="site-form-row">
          <div class="site-form-field">
            <label for="contact-first">First name</label>
            <input id="contact-first" name="firstName" type="text" autocomplete="given-name" required />
          </div>
          <div class="site-form-field">
            <label for="contact-last">Last name</label>
            <input id="contact-last" name="lastName" type="text" autocomplete="family-name" required />
          </div>
        </div>
        <div class="site-form-field">
          <label for="contact-email">Email</label>
          <input id="contact-email" name="email" type="email" autocomplete="email" required />
        </div>
        <div class="site-form-field">
          <label for="contact-message">Message</label>
          <textarea id="contact-message" name="message" rows="6" required></textarea>
        </div>

        <button type="submit" class="site-form-submit">Send</button>
        <p class="site-form-status" data-form-status></p>
      </form>
    </aside>

  </div>
</section>

<script src="{{asset "js/site-forms.js"}}"></script>
