{{!< default}}
<main class="admin-page">
  {{#if @member}}
    <section class="hero admin-hero">
      <div class="container">
        <p class="hero-kicker"><span class="dot"></span> Admin &middot; Groups</p>
        <h1 class="admin-headline">Groups <em><span class="highlight">overview</span></em>.</h1>
        <p class="admin-sub">Every group memberships on the platform. Download the CSV for reporting or cohort work.</p>
      </div>
    </section>

    {{> "admin-nav"}}

    <section class="admin-body">
      <div class="container container-narrow">
        <div class="admin-table-host"
             data-admin-table
             data-title="Groups"
             data-endpoint="/api/admin/groups"
             data-collection="groups"
             data-api-base="{{@custom.membership_api_base}}"
             data-member-email="{{@member.email}}"
             data-columns="org_name,admin_name,admin_email,seat_count,seats_filled,per_seat_usd,status,created_at"
             data-column-labels="Organization,Admin,Email,Seats,Filled,Per seat,Status,Created">
          <div class="admin-table-toolbar">
            <p class="admin-table-count" data-count-label>Loading&hellip;</p>
            <a href="#" class="btn btn-pill btn-primary btn-sm" data-download-csv hidden>Download CSV</a>
          </div>
          <p class="admin-table-status" data-status></p>
          <div class="admin-table-wrap">
            <table class="admin-table" data-table hidden>
              <thead><tr data-thead></tr></thead>
              <tbody data-tbody></tbody>
            </table>
          </div>
        </div>
      </div>
    </section>
  {{else}}
    {{> "admin-denied"}}
  {{/if}}
</main>
<script src="{{asset "js/admin-table.js"}}"></script>
