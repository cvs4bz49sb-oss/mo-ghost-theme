{{!< default}}
{{!-- /dashboard/ebooks/ — paid-only ebook library. Gating mirrors
     the replays page: paid/comped/preview see the body partial;
     anyone else sees an upgrade prompt. --}}

<main class="dashboard">

  {{#unless @member}}
    <section class="hero dashboard-hero">
      <div class="container">
        <p class="hero-kicker"><span class="dot"></span> Member Dashboard</p>
        <h1 class="hero-headline">Sign in to open the <span class="highlight"><em>ebook library</em></span>.</h1>
        <p class="dashboard-actions">
          <a href="#/portal/signin" class="btn btn-primary" data-portal="signin">Sign in</a>
          <a href="/membership/" class="btn btn-ghost">Become a Member</a>
        </p>
      </div>
    </section>
  {{else}}

    {{#match @member.status "paid"}}{{> "dashboard-ebooks-body"}}{{else}}
    {{#match @member.status "comped"}}{{> "dashboard-ebooks-body"}}{{else}}
    {{#match @member.email @custom.dashboard_preview_email}}
      <div class="dashboard-admin-banner" role="note">
        <strong>Admin preview.</strong> You are not a paid Member — this page is visible because your email matches <code>@custom.dashboard_preview_email</code>.
      </div>
      {{> "dashboard-ebooks-body"}}
    {{else}}
      <section class="hero dashboard-hero">
        <div class="container">
          <p class="hero-kicker"><span class="dot"></span> Member Dashboard</p>
          <h1 class="hero-headline">Ebooks are a <span class="highlight"><em>member feature</em></span>.</h1>
          <p>Become a Member to read every Mere Orthodoxy ebook online or as a PDF — plus event replays, the quarterly journal, the full archive, and audio on every essay.</p>
          <p class="dashboard-actions"><a href="/membership/" class="btn btn-primary">Become a Member</a></p>
        </div>
      </section>
    {{/match}}
    {{/match}}
    {{/match}}

  {{/unless}}

</main>
