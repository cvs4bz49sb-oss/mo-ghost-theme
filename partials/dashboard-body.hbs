{{!-- Dashboard body for full-access members (paid, comped, or staff
     preview). Editorial two-column layout: <details> modules on
     the left, identity rail on the right. --}}

<section class="hero dashboard-hero">
  <div class="container">
    <p class="hero-kicker"><span class="dot"></span> Member Dashboard</p>
    <h1 class="hero-headline">
      Welcome, <span class="highlight"><em>{{#if @member.name}}{{@member.name}}{{else}}friend{{/if}}</em></span>.
    </h1>
    <p class="hero-sub">Your home inside Mere Orthodoxy. Bookmarks, reading history, and membership settings — all in one place.</p>
  </div>
</section>

<section class="dashboard-body">
  <div class="container">
    <div class="dashboard-grid">

      <div class="dashboard-main">

        <details class="dashboard-module" open>
          <summary>
            <h2 class="dashboard-module-title"><em>Bookmarks</em></h2>
            <span class="dashboard-module-chev" aria-hidden="true"></span>
          </summary>
          <div class="dashboard-module-body">
            <div class="dashboard-bookmarks"
                 data-dashboard-bookmarks
                 data-limit="5"
                 data-view-all="/dashboard/bookmarks/">
              <p class="dashboard-empty" data-bookmarks-placeholder>Loading your bookmarks&hellip;</p>
            </div>
          </div>
        </details>

        <div class="flourish">{{> "flourish-mark"}}</div>

        <details class="dashboard-module">
          <summary>
            <h2 class="dashboard-module-title"><em>Reading History</em></h2>
            <span class="dashboard-module-chev" aria-hidden="true"></span>
          </summary>
          <div class="dashboard-module-body">
            <div class="dashboard-history"
                 data-dashboard-history
                 data-limit="5"
                 data-view-all="/dashboard/history/">
              <p class="dashboard-empty" data-history-placeholder>Loading your reading history&hellip;</p>
            </div>
          </div>
        </details>

      </div>

      <aside class="dashboard-rail" aria-label="Membership">

        <div class="dashboard-rail-item">
          <p class="eyebrow">Your Membership</p>
          <p class="dashboard-rail-tier"><em>{{#match @member.status "paid"}}Paid Member{{/match}}{{#match @member.status "comped"}}Complimentary{{/match}}{{#match @member.status "free"}}Free Subscriber{{/match}}</em></p>
          {{#if @member.created_at}}
            <p class="dashboard-rail-meta">Member since {{date @member.created_at format="MMMM YYYY"}}</p>
          {{/if}}
          <a href="/manage/" class="dashboard-rail-link">Manage Membership &rarr;</a>
        </div>

        <div class="dashboard-rail-sep" aria-hidden="true"></div>

        <div class="dashboard-rail-item">
          <p class="eyebrow">Replays</p>
          <p class="dashboard-rail-tier"><em>Event Library</em></p>
          <p class="dashboard-rail-meta">Watch every past online event on demand.</p>
          <a href="/dashboard/replays/" class="dashboard-rail-link">Open replay library &rarr;</a>
        </div>

        <div class="dashboard-rail-sep" aria-hidden="true"></div>

        <div class="dashboard-rail-item">
          <p class="eyebrow">Ebooks</p>
          <p class="dashboard-rail-tier"><em>Reading Library</em></p>
          <p class="dashboard-rail-meta">Every Mere Orthodoxy ebook, online or PDF.</p>
          <a href="/dashboard/ebooks/" class="dashboard-rail-link">Open ebook library &rarr;</a>
        </div>

      </aside>

    </div>
  </div>
</section>
