{{!-- Dashboard body for full-access members (paid, comped, or staff
     preview). Editorial layout: dark hero + two-column body with
     <details> modules on the left and a member-info rail on the
     right. Modules are expandable via native <details>/<summary>,
     no JS needed beyond the history fetch in dashboard.js. --}}

<section class="hero dashboard-hero">
  <div class="container">
    <p class="hero-kicker"><span class="dot"></span> Member Dashboard</p>
    <h1 class="hero-headline">
      Welcome, <span class="highlight"><em>{{#if @member.name}}{{@member.name}}{{else}}friend{{/if}}</em></span>.
    </h1>
    <p class="hero-sub">Your home inside Mere Orthodoxy. Reading history, members-only essays, and membership settings — all in one place.</p>
  </div>
</section>

<section class="dashboard-body">
  <div class="container">
    <div class="dashboard-grid">

      <div class="dashboard-main">

        <details class="dashboard-module" open>
          <summary>
            <span class="dashboard-module-eyebrow">Module I</span>
            <h2 class="dashboard-module-title"><em>Members-only Essays</em></h2>
            <span class="dashboard-module-chev" aria-hidden="true"></span>
          </summary>
          <div class="dashboard-module-body">
            {{#get "posts" filter="visibility:paid" limit="6" include="authors,tags" as |members_posts|}}
              {{#if members_posts}}
                <ol class="dashboard-essay-list">
                  {{#foreach members_posts}}
                    <li class="dashboard-essay">
                      <span class="dashboard-essay-numeral">{{@number}}</span>
                      <div class="dashboard-essay-body">
                        {{#if primary_tag}}<p class="dashboard-essay-topic">{{primary_tag.name}}</p>{{/if}}
                        <h3 class="dashboard-essay-title"><a href="{{url}}"><em>{{title}}</em></a></h3>
                        {{#if excerpt}}<p class="dashboard-essay-excerpt">{{excerpt words="24"}}</p>{{/if}}
                      </div>
                    </li>
                  {{/foreach}}
                </ol>
              {{else}}
                <p class="dashboard-empty">No members-only essays published yet.</p>
              {{/if}}
            {{/get}}
          </div>
        </details>

        <div class="flourish">{{> "flourish-mark"}}</div>

        <details class="dashboard-module" open>
          <summary>
            <span class="dashboard-module-eyebrow">Module II</span>
            <h2 class="dashboard-module-title"><em>Your Reading History</em></h2>
            <span class="dashboard-module-chev" aria-hidden="true"></span>
          </summary>
          <div class="dashboard-module-body">
            <div class="dashboard-history" data-dashboard-history>
              <p class="dashboard-empty" data-history-placeholder>Loading your reading history&hellip;</p>
            </div>
          </div>
        </details>

      </div>

      <aside class="dashboard-rail" aria-label="Membership">

        <div class="dashboard-rail-card">
          <p class="eyebrow">Your Membership</p>
          <p class="dashboard-rail-tier"><em>{{#match @member.status "paid"}}Paid Member{{/match}}{{#match @member.status "comped"}}Complimentary{{/match}}{{#match @member.status "free"}}Free Subscriber{{/match}}</em></p>
          {{#if @member.created_at}}
            <p class="dashboard-rail-meta">Member since {{date @member.created_at format="MMMM YYYY"}}</p>
          {{/if}}
          <a href="/manage/" class="btn btn-primary dashboard-rail-btn">Manage Membership</a>
        </div>

        <div class="dashboard-rail-card dashboard-rail-card--soft">
          <p class="eyebrow">Listen</p>
          <p class="dashboard-rail-body">Every new essay is narrated and available as an audio article. Tap <em>Listen to this essay</em> on any post.</p>
        </div>

      </aside>

    </div>
  </div>
</section>
