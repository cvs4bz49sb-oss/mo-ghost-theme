{{!-- Dashboard body for full-access members (paid, comped, or staff
     preview). Editorial two-column layout: <details> modules on
     the left, identity rail on the right. --}}

<section class="hero dashboard-hero">
  <div class="container">
    <p class="hero-kicker"><span class="dot"></span> Member Dashboard</p>
    <h1 class="hero-headline">
      Welcome, <span class="highlight"><em>{{#if @member.name}}{{@member.name}}{{else}}friend{{/if}}</em></span>.
    </h1>
    <p class="hero-sub">Your home inside Mere Orthodoxy. Bookmarks, reading history, and membership settings — all in one place.</p>
  </div>
</section>

<section class="dashboard-body">
  <div class="container">
    <div class="dashboard-grid">

      <div class="dashboard-main">

        <details class="dashboard-module" open>
          <summary>
            <h2 class="dashboard-module-title"><em>Bookmarks</em></h2>
            <span class="dashboard-module-chev" aria-hidden="true"></span>
          </summary>
          <div class="dashboard-module-body">
            <div class="dashboard-bookmarks"
                 data-dashboard-bookmarks
                 data-limit="4"
                 data-view-all="/dashboard/bookmarks/">
              <p class="dashboard-empty" data-bookmarks-placeholder>Loading your bookmarks&hellip;</p>
            </div>
          </div>
        </details>

        <div class="flourish">{{> "flourish-mark"}}</div>

        <details class="dashboard-module" open>
          <summary>
            <h2 class="dashboard-module-title"><em>Ebooks</em></h2>
            <span class="dashboard-module-chev" aria-hidden="true"></span>
          </summary>
          <div class="dashboard-module-body">
            {{> "ebooks-list"}}
            <p class="dashboard-view-all">
              <a href="/dashboard/ebooks/">View the full library &rarr;</a>
            </p>
          </div>
        </details>

        <div class="flourish">{{> "flourish-mark"}}</div>

        <details class="dashboard-module">
          <summary>
            <h2 class="dashboard-module-title"><em>Reading History</em></h2>
            <span class="dashboard-module-chev" aria-hidden="true"></span>
          </summary>
          <div class="dashboard-module-body">
            <div class="dashboard-history"
                 data-dashboard-history
                 data-limit="4"
                 data-view-all="/dashboard/history/">
              <p class="dashboard-empty" data-history-placeholder>Loading your reading history&hellip;</p>
            </div>
          </div>
        </details>

        <div class="flourish">{{> "flourish-mark"}}</div>

        {{!-- Shipping address — the print journal is mailed to
             whatever's stored here. Dashboard-level visibility rules
             already gate the page to paid / comped / admin-preview
             members, so this module renders unconditionally here. --}}
        <details class="dashboard-module">
          <summary>
            <h2 class="dashboard-module-title"><em>Shipping Address</em></h2>
            <span class="dashboard-module-chev" aria-hidden="true"></span>
          </summary>
          <div class="dashboard-module-body">
            <div class="dashboard-address"
                 data-dashboard-address
                 data-member-email="{{@member.email}}"
                 data-member-name="{{@member.name}}"
                 data-api-base="{{@custom.membership_api_base}}">
              <p class="dashboard-empty" data-address-placeholder>Loading your address&hellip;</p>

              <div class="dashboard-address-view" data-address-view hidden>
                <p class="eyebrow dashboard-address-eyebrow">On file</p>
                <p class="dashboard-address-display" data-address-display></p>
                <button type="button" class="dashboard-inline-link" data-address-edit>Edit address &rarr;</button>
              </div>

              <div class="dashboard-address-empty" data-address-empty hidden>
                <p class="dashboard-address-lede">The print journal goes out quarterly. Add your address so you don't miss the next issue.</p>
                <button type="button" class="dashboard-inline-link" data-address-edit>Add your address &rarr;</button>
              </div>

              <form class="dashboard-address-form" data-address-form hidden novalidate>
                <div class="dashboard-form-group">
                  <p class="dashboard-form-legend"><em>Recipient</em></p>
                  <label class="dashboard-form-field">
                    <span class="dashboard-form-label">Full name on label</span>
                    <input type="text" name="name" autocomplete="name" required />
                  </label>
                </div>

                <div class="dashboard-form-group">
                  <p class="dashboard-form-legend"><em>Address</em></p>
                  <label class="dashboard-form-field">
                    <span class="dashboard-form-label">Street</span>
                    <input type="text" name="line1" autocomplete="address-line1" required />
                  </label>
                  <label class="dashboard-form-field">
                    <span class="dashboard-form-label">Apartment, suite, or unit <span class="dashboard-form-hint">(optional)</span></span>
                    <input type="text" name="line2" autocomplete="address-line2" />
                  </label>
                  <div class="dashboard-form-row">
                    <label class="dashboard-form-field">
                      <span class="dashboard-form-label">City</span>
                      <input type="text" name="city" autocomplete="address-level2" required />
                    </label>
                    <label class="dashboard-form-field">
                      <span class="dashboard-form-label">State / Province</span>
                      <input type="text" name="state" autocomplete="address-level1" maxlength="3" required />
                    </label>
                  </div>
                  <div class="dashboard-form-row">
                    <label class="dashboard-form-field">
                      <span class="dashboard-form-label">ZIP / Postal code</span>
                      <input type="text" name="postal_code" autocomplete="postal-code" required />
                    </label>
                    <label class="dashboard-form-field">
                      <span class="dashboard-form-label">Country</span>
                      <select name="country" required>
                        <option value="US">United States</option>
                        <option value="CA">Canada</option>
                      </select>
                    </label>
                  </div>
                </div>

                <div class="dashboard-address-actions">
                  <button type="submit" class="btn btn-pill btn-primary" data-address-submit>Save address</button>
                  <button type="button" class="dashboard-inline-link dashboard-inline-link--muted" data-address-cancel>Cancel</button>
                </div>
                <p class="btn-error" data-address-error role="alert"></p>
                <p class="dashboard-form-success" data-address-success hidden>Saved.</p>
              </form>
            </div>
          </div>
        </details>

      </div>

      <aside class="dashboard-rail" aria-label="Membership">

        <div class="dashboard-rail-item">
          <p class="eyebrow">Your Membership</p>
          <p class="dashboard-rail-tier"><em>{{#match @member.status "paid"}}Paid Member{{/match}}{{#match @member.status "comped"}}Complimentary{{/match}}{{#match @member.status "free"}}Free Subscriber{{/match}}</em></p>
          {{#if @member.created_at}}
            <p class="dashboard-rail-meta">Member since {{date @member.created_at format="MMMM YYYY"}}</p>
          {{/if}}
          <a href="/manage/" class="dashboard-rail-link">Manage Membership &rarr;</a>
        </div>

        <div class="dashboard-rail-sep" aria-hidden="true"></div>

        <div class="dashboard-rail-item">
          <p class="eyebrow">Replays</p>
          <p class="dashboard-rail-tier"><em>Event Library</em></p>
          <p class="dashboard-rail-meta">Watch every past online event on demand.</p>
          <a href="/dashboard/replays/" class="dashboard-rail-link">Open replay library &rarr;</a>
        </div>

        <div class="dashboard-rail-sep" aria-hidden="true"></div>

        <div class="dashboard-rail-item">
          <p class="eyebrow">Ebooks</p>
          <p class="dashboard-rail-tier"><em>Reading Library</em></p>
          <p class="dashboard-rail-meta">Every Mere Orthodoxy ebook, online or PDF.</p>
          <a href="/dashboard/ebooks/" class="dashboard-rail-link">Open ebook library &rarr;</a>
        </div>

      </aside>

    </div>
  </div>
</section>
