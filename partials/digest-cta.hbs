<section class="digest-section" id="digest" aria-label="Weekly Digest newsletter signup">
    <div class="container">
        <div class="digest-cta">
            <div class="digest-copy">
                <p class="eyebrow">The Weekly Digest</p>
                <h3>Premier Thought Every Thursday</h3>
                <p>An essay worth your time, a handful of links worth reading, and a short note from our editors. No hype. No filler. Unsubscribe anytime.</p>
            </div>
            {{#if @custom.digest_form_action}}
                {{!-- External service (Kit / Mailchimp). Leave form submit
                     to the external action. Only used when admin explicitly
                     sets @custom.digest_form_action. --}}
                <form class="digest-form" action="{{@custom.digest_form_action}}" method="POST">
                    <div class="digest-field">
                        <label for="digest-first">First Name</label>
                        <input id="digest-first" type="text" name="first_name" autocomplete="given-name" placeholder="First" required />
                    </div>
                    <div class="digest-field">
                        <label for="digest-last">Last Name</label>
                        <input id="digest-last" type="text" name="last_name" autocomplete="family-name" placeholder="Last" required />
                    </div>
                    <div class="digest-field">
                        <label for="digest-email">Email</label>
                        <input id="digest-email" type="email" name="email" autocomplete="email" placeholder="you@example.com" required />
                    </div>
                    <button type="submit" class="digest-submit">Subscribe</button>
                    <p class="digest-fineprint">Free. Delivered Thursday mornings.</p>
                </form>
            {{else}}
                {{!-- Ghost-native inline signup. inline-signup.js POSTs the
                     values straight to /members/api/send-magic-link/ and
                     swaps the form for a success state. No Portal modal. --}}
                <div class="digest-form" data-inline-signup>
                    <div class="digest-field">
                        <label for="digest-first">First Name</label>
                        <input id="digest-first" type="text" autocomplete="given-name" placeholder="First" data-signup-first required />
                    </div>
                    <div class="digest-field">
                        <label for="digest-last">Last Name</label>
                        <input id="digest-last" type="text" autocomplete="family-name" placeholder="Last" data-signup-last required />
                    </div>
                    <div class="digest-field">
                        <label for="digest-email">Email</label>
                        <input id="digest-email" type="email" autocomplete="email" placeholder="you@example.com" data-signup-email required />
                    </div>
                    <button type="button" class="digest-submit" data-signup-submit>Subscribe</button>
                    <p class="digest-fineprint">Free. Delivered Thursday mornings.</p>
                    <p class="digest-status" data-signup-status></p>
                </div>
            {{/if}}
        </div>
    </div>
</section>
