{{!-- Body for /dashboard/ebooks/. Paid-member ebook library.

     Each card links to the ebook subdomain. When @custom.ebook_access_worker_url
     is set, dashboard-ebooks.js mints a short-lived HMAC token via the
     mo-ebook-access worker and rewrites flagged links (data-requires-token)
     to include ?t=TOKEN so paid Ghost members skip the ebook's HubSpot-list
     gate. Without the worker URL the links still resolve — the HubSpot gate
     just handles auth as before. --}}

<section class="hero dashboard-hero">
  <div class="container">
    <p class="hero-kicker"><span class="dot"></span> Member Dashboard</p>
    <h1 class="hero-headline"><span class="highlight"><em>Ebook</em></span> Library.</h1>
    <p class="hero-sub">Every Mere Orthodoxy ebook, in one place. Click through to read online or download a PDF.</p>
    <p class="dashboard-breadcrumb"><a href="/dashboard/">&larr; Back to dashboard</a></p>
  </div>
</section>

<section class="dashboard-body">
  <div class="container container-narrow">
    <ul class="ebooks-grid"
        data-ebooks
        data-member-email="{{@member.email}}"
        data-worker-url="{{@custom.ebook_access_worker_url}}">

      <li class="ebook-card">
        <a href="https://christian-formation.up.railway.app/"
           data-ebook-link
           data-requires-token="true"
           data-verify-path="/api/ghost-verify"
           class="ebook-card-link"
           target="_blank"
           rel="noopener">
          <span class="ebook-card-eyebrow">Ebook</span>
          <h2 class="ebook-card-title"><em>Christian Formation in The Modern World</em></h2>
          <p class="ebook-card-excerpt">A collection on shaping Christian lives under the conditions of modernity.</p>
          <span class="ebook-card-cta">Open ebook &rarr;</span>
        </a>
      </li>

      <li class="ebook-card">
        <a href="https://christians-in-an-ai-world.up.railway.app/"
           data-ebook-link
           class="ebook-card-link"
           target="_blank"
           rel="noopener">
          <span class="ebook-card-eyebrow">Ebook</span>
          <h2 class="ebook-card-title"><em>Christians In An AI World</em></h2>
          <p class="ebook-card-excerpt">Theological and practical reflections for the age of artificial intelligence.</p>
          <span class="ebook-card-cta">Open ebook &rarr;</span>
        </a>
      </li>

    </ul>
  </div>
</section>
