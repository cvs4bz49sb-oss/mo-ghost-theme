{{!-- Pricing cards section for /membership/ — Member ($100/yr or
     $10/mo via Portal) + Lifetime ($995, mo-membership worker) +
     "other ways" rail (Gift / Groups / Institutions). Extracted so
     partials/membership-body.hbs can reference this from BOTH the
     signed-in-free-Subscriber branch AND the anonymous branch
     without duplicating ~90 lines of markup. Anyone visiting
     /membership/ who isn't paid/comped/staff-preview should see
     this exact block. --}}
<section class="pricing">
  <div class="container">
    <div class="cards">
      <article class="card card-member is-featured">
        <span class="card-flag">Most Popular</span>
        <p class="card-label"><em>Member</em></p>
        <div class="card-price" data-price-display>
          <span class="price-amount" data-price-annual-amount="$100" data-price-monthly-amount="$10">$100</span>
          <span class="price-interval" data-price-annual-interval="/yr" data-price-monthly-interval="/mo">/yr</span>
        </div>
        <p class="card-subtext" data-price-subtext data-price-annual-subtext="Just 27¢/day" data-price-monthly-subtext="Billed monthly">Just 27¢/day</p>
        <p class="card-pitch">For readers who want serious Christian journalism and the quarterly print journal.</p>
        <a
          class="btn btn-pill btn-primary"
          id="member-cta"
          href="#/portal/signup"
          data-portal="signup"
        >Become a Member</a>
        <p class="btn-tagline">Cancel anytime</p>
        <ul class="benefits">
          <li>The quarterly print journal, mailed to your door</li>
          <li>Private Discord community of serious readers</li>
          <li>Ebook and online event library</li>
          <li>Monthly Mailbag from Jake Meador</li>
          <li>The full archive, including 20+ years of essays</li>
          <li>Audio versions of every article</li>
          <li>Bookmarks</li>
          <li>Member Dashboard</li>
        </ul>
      </article>

      <article class="card card-lifetime">
        <p class="card-label"><em>Lifetime</em></p>
        <div class="card-price">
          <span class="price-amount">$995</span>
        </div>
        <p class="card-subtext">One-time payment</p>
        <p class="card-pitch">For readers who want to help sustain Mere&nbsp;Orthodoxy permanently.</p>
        {{!-- Ghost Portal doesn't support one-time purchases, so
             lifetime routes through the mo-membership worker:
             click → POST /api/create-lifetime-checkout → Stripe
             Checkout (collects email + shipping) → webhook
             provisions Ghost member with lifetime tier. --}}
        <button
          type="button"
          class="btn btn-pill btn-dark"
          data-lifetime-checkout
          data-member-email="{{#if @member}}{{@member.email}}{{/if}}"
          data-member-name="{{#if @member}}{{@member.name}}{{/if}}"
        >
          <span class="btn-label">Become a Lifetime Member</span>
          <span class="btn-spinner" aria-hidden="true"></span>
        </button>
        <p class="btn-tagline">One-time. No renewal.</p>
        <p class="btn-error" data-lifetime-error role="alert"></p>
        <ul class="benefits">
          <li><strong>Everything in Member, plus:</strong></li>
          <li>A copy of Jake Meador's <em>In Search Of The Common Good: Christian Fidelity In A Fractured World</em></li>
        </ul>
      </article>
    </div>

    <div class="other-ways">
      <div class="other-ways-intro">
        <p class="eyebrow">Other Memberships</p>
        <h2 class="section-heading"><em>Share Mere&nbsp;Orthodoxy<br class="mobile-only" /> With Others</em></h2>
      </div>
      <div class="other-ways-grid">
        <article class="other-way is-featured">
          <span class="other-way-numeral">I</span>
          <h3 class="other-way-title"><em>Give a membership</em></h3>
          <p class="other-way-body">A year of Mere&nbsp;Orthodoxy for a friend, a pastor, or a seminary student.</p>
          <a href="/give/" class="other-way-link">Give a gift <span aria-hidden="true">&rarr;</span></a>
        </article>
        <article class="other-way">
          <span class="other-way-numeral">II</span>
          <h3 class="other-way-title"><em>For your organization</em></h3>
          <p class="other-way-body">Churches, staffs, and cohorts. Volume pricing starting at five seats.</p>
          <a href="/groups/" class="other-way-link">See group pricing <span aria-hidden="true">&rarr;</span></a>
        </article>
        <article class="other-way">
          <span class="other-way-numeral">III</span>
          <h3 class="other-way-title"><em>Seminaries &amp; institutions</em></h3>
          <p class="other-way-body">Domain-based access for schools, denominations, and larger partners.</p>
          <a href="/institutions/" class="other-way-link">Start a conversation <span aria-hidden="true">&rarr;</span></a>
        </article>
      </div>
    </div>
  </div>
</section>
