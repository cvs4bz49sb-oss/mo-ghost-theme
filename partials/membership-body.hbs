  <script>
    (function () {
      // Billing-interval toggle for the Member tier. Flips the
      // displayed price / interval / subtext between annual and
      // monthly. Ghost Portal handles the actual tier selection at
      // checkout, so the CTA href is always #/portal/signup.
      var toggles = document.querySelectorAll('.toggle-option[data-interval]');
      var priceAmount = document.querySelector('[data-price-annual-amount]');
      var priceInterval = document.querySelector('[data-price-annual-interval]');
      var priceSubtext = document.querySelector('[data-price-subtext]');
      if (!toggles.length || !priceAmount || !priceInterval || !priceSubtext) return;

      function apply(interval) {
        toggles.forEach(function (t) {
          var active = t.getAttribute('data-interval') === interval;
          t.classList.toggle('is-active', active);
          t.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        priceAmount.textContent = priceAmount.getAttribute('data-price-' + interval + '-amount') || priceAmount.textContent;
        priceInterval.textContent = priceInterval.getAttribute('data-price-' + interval + '-interval') || priceInterval.textContent;
        priceSubtext.textContent = priceSubtext.getAttribute('data-price-' + interval + '-subtext') || priceSubtext.textContent;
      }

      toggles.forEach(function (t) {
        t.addEventListener('click', function () { apply(t.getAttribute('data-interval')); });
      });
    })();
  </script>
  <script src="{{asset "js/lifetime-checkout.js"}}"></script>
