{{!-- /admin/ landing: tiles for each tool. No cards — editorial
     rows with eyebrow + title + short description + arrow. --}}

<section class="hero admin-hero">
  <div class="container">
    <p class="hero-kicker"><span class="dot"></span> Admin</p>
    <h1 class="admin-headline">Mere&nbsp;Orthodoxy <em><span class="highlight">Operations</span></em>.</h1>
    <p class="admin-sub">Every tool for running the publication, in one place.</p>
  </div>
</section>

{{> "admin-nav"}}

<section class="admin-body">
  <div class="container container-narrow">
    <ul class="admin-tool-list">
      <li class="admin-tool">
        <a href="/admin/members/" class="admin-tool-link">
          <span class="admin-tool-numeral">I</span>
          <div class="admin-tool-body">
            <p class="eyebrow">Analytics</p>
            <h2 class="admin-tool-title"><em>Members</em></h2>
            <p class="admin-tool-desc">Counts by tier, new signups this week / month, timeseries, recent activity.</p>
          </div>
          <span class="admin-tool-arrow" aria-hidden="true">&rarr;</span>
        </a>
      </li>
      <li class="admin-tool">
        <a href="/admin/addresses/" class="admin-tool-link">
          <span class="admin-tool-numeral">II</span>
          <div class="admin-tool-body">
            <p class="eyebrow">Fulfillment</p>
            <h2 class="admin-tool-title"><em>Addresses</em></h2>
            <p class="admin-tool-desc">Every shipping address on file. Download the CSV to generate labels for the print journal run.</p>
          </div>
          <span class="admin-tool-arrow" aria-hidden="true">&rarr;</span>
        </a>
      </li>
      <li class="admin-tool">
        <a href="/admin/gifts/" class="admin-tool-link">
          <span class="admin-tool-numeral">III</span>
          <div class="admin-tool-body">
            <p class="eyebrow">Memberships</p>
            <h2 class="admin-tool-title"><em>Gifts</em></h2>
            <p class="admin-tool-desc">Gift memberships purchased, recipients, expiration dates.</p>
          </div>
          <span class="admin-tool-arrow" aria-hidden="true">&rarr;</span>
        </a>
      </li>
      <li class="admin-tool">
        <a href="/admin/groups/" class="admin-tool-link">
          <span class="admin-tool-numeral">IV</span>
          <div class="admin-tool-body">
            <p class="eyebrow">Memberships</p>
            <h2 class="admin-tool-title"><em>Groups</em></h2>
            <p class="admin-tool-desc">Active group subscriptions with seat counts and admin contacts.</p>
          </div>
          <span class="admin-tool-arrow" aria-hidden="true">&rarr;</span>
        </a>
      </li>
      <li class="admin-tool">
        <a href="/admin/institutions/" class="admin-tool-link">
          <span class="admin-tool-numeral">V</span>
          <div class="admin-tool-body">
            <p class="eyebrow">Memberships</p>
            <h2 class="admin-tool-title"><em>Institutions</em></h2>
            <p class="admin-tool-desc">Seminary / college / denomination partnerships, domain allowlists, contract dates.</p>
          </div>
          <span class="admin-tool-arrow" aria-hidden="true">&rarr;</span>
        </a>
      </li>
      <li class="admin-tool">
        <a href="/admin/drift/" class="admin-tool-link">
          <span class="admin-tool-numeral">VI</span>
          <div class="admin-tool-body">
            <p class="eyebrow">Reconciliation</p>
            <h2 class="admin-tool-title"><em>Drift</em></h2>
            <p class="admin-tool-desc">Ghost vs Kit reconciliation report. Flags members who exist on one side but not the other, or whose tiers disagree.</p>
          </div>
          <span class="admin-tool-arrow" aria-hidden="true">&rarr;</span>
        </a>
      </li>
      <li class="admin-tool admin-tool--pending">
        <div class="admin-tool-link">
          <span class="admin-tool-numeral">VII</span>
          <div class="admin-tool-body">
            <p class="eyebrow">Analytics</p>
            <h2 class="admin-tool-title"><em>Traffic</em></h2>
            <p class="admin-tool-desc">Top articles, top topics, top regions, time-of-day — via Plausible.</p>
          </div>
          <span class="admin-tool-soon">Soon</span>
        </div>
      </li>
      <li class="admin-tool admin-tool--pending">
        <div class="admin-tool-link">
          <span class="admin-tool-numeral">VIII</span>
          <div class="admin-tool-body">
            <p class="eyebrow">Workflow</p>
            <h2 class="admin-tool-title"><em>Editorial Kanban</em></h2>
            <p class="admin-tool-desc">Submissions, approved, edited, scheduled, published, denied.</p>
          </div>
          <span class="admin-tool-soon">Soon</span>
        </div>
      </li>
      <li class="admin-tool admin-tool--pending">
        <div class="admin-tool-link">
          <span class="admin-tool-numeral">IX</span>
          <div class="admin-tool-body">
            <p class="eyebrow">Analytics</p>
            <h2 class="admin-tool-title"><em>Podcasts</em></h2>
            <p class="admin-tool-desc">Downloads, top episodes, listener geography — once host API picked.</p>
          </div>
          <span class="admin-tool-soon">Soon</span>
        </div>
      </li>
      <li class="admin-tool admin-tool--pending">
        <div class="admin-tool-link">
          <span class="admin-tool-numeral">X</span>
          <div class="admin-tool-body">
            <p class="eyebrow">Revenue</p>
            <h2 class="admin-tool-title"><em>Sponsorships</em></h2>
            <p class="admin-tool-desc">Sponsor directory, placements, invoice status.</p>
          </div>
          <span class="admin-tool-soon">Soon</span>
        </div>
      </li>
    </ul>
  </div>
</section>
