{{!-- /admin/ landing: tiles for each tool. No cards — editorial
     rows with eyebrow + title + short description + arrow.

     Addresses / Gifts / Groups / Institutions / Drift moved under
     /admin/members/* with a sidebar nav; they no longer get their
     own tiles here. --}}

<section class="hero admin-hero">
  <div class="container">
    <p class="hero-kicker"><span class="dot"></span> Admin</p>
    <h1 class="admin-headline">Mere&nbsp;Orthodoxy <em><span class="highlight">Operations</span></em>.</h1>
    <p class="admin-sub">Every tool for running the publication, in one place.</p>
  </div>
</section>

{{> "admin-nav"}}

<section class="admin-body">
  <div class="container container-narrow">
    <ul class="admin-tool-list">
      <li class="admin-tool">
        <a href="/admin/members/" class="admin-tool-link">
          <span class="admin-tool-numeral">I</span>
          <div class="admin-tool-body">
            <p class="eyebrow">Membership</p>
            <h2 class="admin-tool-title"><em>Members</em></h2>
            <p class="admin-tool-desc">Analytics, addresses, gifts, groups, institutions, and Ghost&harr;Kit drift — all under one dashboard.</p>
          </div>
          <span class="admin-tool-arrow" aria-hidden="true">&rarr;</span>
        </a>
      </li>
      <li class="admin-tool">
        <a href="/admin/traffic/" class="admin-tool-link">
          <span class="admin-tool-numeral">II</span>
          <div class="admin-tool-body">
            <p class="eyebrow">Analytics</p>
            <h2 class="admin-tool-title"><em>Traffic</em></h2>
            <p class="admin-tool-desc">Top pages, top sources, top regions, day-over-day visitors — via Plausible.</p>
          </div>
          <span class="admin-tool-arrow" aria-hidden="true">&rarr;</span>
        </a>
      </li>
      <li class="admin-tool">
        <a href="/admin/editorial/" class="admin-tool-link">
          <span class="admin-tool-numeral">III</span>
          <div class="admin-tool-body">
            <p class="eyebrow">Workflow</p>
            <h2 class="admin-tool-title"><em>Editorial</em></h2>
            <p class="admin-tool-desc">Submissions inbox plus a workflow board to track each piece from approved through published.</p>
          </div>
          <span class="admin-tool-arrow" aria-hidden="true">&rarr;</span>
        </a>
      </li>
      <li class="admin-tool admin-tool--pending">
        <div class="admin-tool-link">
          <span class="admin-tool-numeral">IV</span>
          <div class="admin-tool-body">
            <p class="eyebrow">Analytics</p>
            <h2 class="admin-tool-title"><em>Podcasts</em></h2>
            <p class="admin-tool-desc">Downloads, top episodes, listener geography — once host API picked.</p>
          </div>
          <span class="admin-tool-soon">Soon</span>
        </div>
      </li>
      <li class="admin-tool admin-tool--pending">
        <div class="admin-tool-link">
          <span class="admin-tool-numeral">V</span>
          <div class="admin-tool-body">
            <p class="eyebrow">Revenue</p>
            <h2 class="admin-tool-title"><em>Sponsorships</em></h2>
            <p class="admin-tool-desc">Sponsor directory, placements, invoice status.</p>
          </div>
          <span class="admin-tool-soon">Soon</span>
        </div>
      </li>
    </ul>
  </div>
</section>
