{{!-- Right-column signup card for an ebook landing page.

     Usage (from a custom-ebook-<slug>.hbs template):
       {{> "ebook-signup" slug="navigating-the-fracture"
                          title="Navigating the Fracture"
                          read_url="/ebook/navigating-the-fracture/read/" }}

     Architecture (B+, Ghost-native, post-Railway):
       - Read pages have `visibility: members`. Ghost gates anonymous
         visitors natively; any signed-in member (free or paid) can
         read any ebook. There is NO per-ebook access gate.
       - The form posts to the mo-ebook-access /grant endpoint, which
         creates a free Ghost member if needed and writes attribution
         labels (`ebook:<slug>` and `source:ebook-<slug>`). mo-kit
         mirrors them to Kit tags so per-ebook conversion sequences
         can fire.
       - For signed-in visitors, the card just shows "Open the ebook"
         — a plain anchor to /ebook/<slug>/read/.
--}}

<aside class="ebook-landing"
       data-ebook-landing
       data-ebook-slug="{{slug}}"
       data-ebook-title="{{title}}"
       data-ebook-read-url="{{read_url}}"
       data-worker-url="{{@custom.ebook_access_worker_url}}"
       data-member-email="{{#if @member}}{{@member.email}}{{/if}}">

  <div class="ebook-landing-card" data-ebook-card>

    <div class="ebook-landing-form" data-ebook-signup data-inline-signup data-source="ebook-{{slug}}">
      <p class="eyebrow">Free Subscriber Ebook</p>
      <h2 class="ebook-landing-form-title">Read it free.</h2>
      <p class="ebook-landing-form-sub">Tell us where to send your link. You'll get this ebook plus our weekly newsletter.</p>

      <div class="digest-form ebook-landing-form-fields">
        <div class="digest-field">
          <label for="ebook-{{slug}}-first">First Name</label>
          <input id="ebook-{{slug}}-first" type="text" autocomplete="given-name" placeholder="First" data-signup-first />
        </div>
        <div class="digest-field">
          <label for="ebook-{{slug}}-last">Last Name</label>
          <input id="ebook-{{slug}}-last" type="text" autocomplete="family-name" placeholder="Last" data-signup-last />
        </div>
        <div class="digest-field">
          <label for="ebook-{{slug}}-email">Email</label>
          <input id="ebook-{{slug}}-email" type="email" autocomplete="email" placeholder="you@example.com" data-signup-email required />
        </div>
        <button type="button" class="digest-submit" data-signup-submit>Send me the ebook</button>
        <p class="digest-fineprint">Free signup. Unsubscribe anytime.</p>
        <p class="digest-status" data-signup-status></p>
      </div>
    </div>

    <div class="ebook-landing-open" data-ebook-open hidden>
      <p class="eyebrow">You're in</p>
      <h2 class="ebook-landing-form-title">Open <em>{{title}}</em>.</h2>
      <p class="ebook-landing-form-sub">Click below to start reading.</p>
      <a href="{{read_url}}" class="btn btn-primary btn-lg ebook-landing-open-btn" data-ebook-open-btn target="_blank" rel="noopener">Open the ebook &rarr;</a>
    </div>

  </div>
</aside>
