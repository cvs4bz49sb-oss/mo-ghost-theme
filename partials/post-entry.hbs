<a href="{{url}}" class="entry">
    <div class="entry-plate">
        <div class="entry-plate-inner"{{#if feature_image}} style="background-image: url({{img_url feature_image size="m"}});"{{/if}}></div>
    </div>
    <div class="entry-text">
        {{!-- Eyebrow topic: first non-author tag. Ghost's primary_tag
             returns whichever tag is first in tag order, which is often
             an author- contributor tag on this site. We render every
             tag as a candidate and let CSS pick the first one whose
             slug doesn't start with "author-". --}}
        <p class="entry-topic entry-topic--candidates" data-topic>
            {{#foreach tags}}<span class="entry-topic-tag" data-tag-slug="{{slug}}">{{name}}</span>{{/foreach}}
        </p>
        <h3 class="entry-title">{{title}}</h3>
        {{#if custom_excerpt}}
            <p class="entry-excerpt entry-excerpt-dropcap">{{custom_excerpt}}</p>
        {{else}}
            {{#if excerpt}}
                <p class="entry-excerpt entry-excerpt-dropcap">{{excerpt words="30"}}</p>
            {{/if}}
        {{/if}}
        <div class="entry-meta">
            {{!-- Contributor byline override: any author- slug tag replaces the staff author.
                 See post.hbs for the full convention note. --}}
            <p class="entry-byline entry-byline-contributors" data-byline>
                <span class="entry-byline-prefix">By </span>
                {{#foreach tags}}<em class="entry-contributor entry-contributor--candidate" data-tag-slug="{{slug}}">{{name}}</em>{{/foreach}}
            </p>
            <p class="entry-byline entry-byline-fallback">
                {{#primary_author}}By <em>{{name}}</em>{{/primary_author}}
            </p>
            <p class="entry-date">{{date format="MMMM D"}} &middot; {{reading_time minute="1 min read" minutes="% min read"}}</p>
        </div>
    </div>
</a>
