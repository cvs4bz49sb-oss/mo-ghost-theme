{{!< default}}

{{#post}}

<article>
    <header class="article-header">
        <div class="article-header-inner">
            {{!-- Topic pill: render every public tag; CSS hides
                 author-* slugs and separates the rest with "·". --}}
            <p class="article-topic article-topic--candidates" data-topic>
                {{#foreach tags visibility="public"}}<a href="{{url}}" class="article-topic-tag" data-tag-slug="{{slug}}">{{name}}</a>{{/foreach}}
            </p>
            <h1 class="article-title">{{title}}</h1>
            {{#if custom_excerpt}}
                <p class="article-dek">{{custom_excerpt}}</p>
            {{/if}}
            <div class="article-meta">
                {{!-- Contributor byline: any tag whose slug starts with "author-" overrides
                     the Ghost staff author. Lets us credit 30+ writers without paying for
                     extra staff seats. When no author- tag exists, fall back to primary_author. --}}
                <span class="meta-authors" data-byline>
                    {{!-- Every tag is emitted with data-tag-slug. CSS prefix-selectors
                         (data-tag-slug^="author-") show only contributor tags and hide
                         the fallback below. Ghost's match helper has no regex operator,
                         so attribute selectors do the filtering. --}}
                    {{#foreach tags}}
                        <a href="{{url}}" class="meta-author meta-author--candidate" data-tag-slug="{{slug}}">
                            <div class="meta-avatar" aria-hidden="true">
                                {{#if feature_image}}
                                    <img src="{{img_url feature_image size="xs"}}" alt="{{name}}" />
                                {{else}}
                                    <span class="meta-avatar-initial">{{name}}</span>
                                {{/if}}
                            </div>
                            <div>
                                <div class="meta-author-name"><em>{{name}}</em></div>
                                {{#if description}}<div class="meta-author-sub">Contributor</div>{{/if}}
                            </div>
                        </a>
                    {{/foreach}}
                </span>
                <span class="meta-authors-fallback">
                    {{#primary_author}}
                        <a href="{{url}}" class="meta-author">
                            <div class="meta-avatar" aria-hidden="true">
                                {{#if profile_image}}
                                    <img src="{{img_url profile_image size="xs"}}" alt="{{name}}" />
                                {{else}}
                                    <span class="meta-avatar-initial">{{name}}</span>
                                {{/if}}
                            </div>
                            <div>
                                <div class="meta-author-name"><em>{{name}}</em></div>
                                {{#if bio}}<div class="meta-author-sub">Contributing Writer</div>{{/if}}
                            </div>
                        </a>
                    {{/primary_author}}
                </span>
                <span class="meta-dot">&bull;</span>
                <span class="meta-item">{{date format="MMMM D, YYYY"}}</span>
                <span class="meta-dot">&bull;</span>
                <span class="meta-item">{{reading_time minute="1 min read" minutes="% min read"}}</span>
            </div>

            {{!-- Audio article: any signed-in member (free or paid).
                 Signed-out visitors don't see the button. Click swaps
                 the button for an inline HTML5 audio player pointing
                 at the mo-audio worker. Archive posts are synthesized
                 on first play; new posts are pre-warmed via webhook. --}}
            {{!-- Audio player + Bookmark are visible to everyone so
                 the value is obvious at a glance. Click behavior is
                 paid-gated in article-audio.js and article-bookmark.js
                 — non-paid visitors get redirected to /membership/.
                 The inline note below states the gate explicitly. --}}
            <div class="article-actions">
                {{#if @custom.audio_worker_url}}
                    <div class="article-audio"
                         data-article-audio
                         data-post-id="{{id}}"
                         data-audio-base="{{@custom.audio_worker_url}}"
                         data-post-title="{{title}}"
                         data-post-author="{{#if primary_author}}{{primary_author.name}}{{else}}Mere Orthodoxy{{/if}}"
                         {{#if feature_image}}data-post-image="{{img_url feature_image size="m"}}"{{/if}}>
                        <button class="article-audio-trigger" type="button" data-audio-trigger aria-label="Listen to this essay">
                            <svg class="article-audio-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M7 5l12 7-12 7V5z"/></svg>
                            <span class="article-audio-label">Listen to this essay</span>
                        </button>
                    </div>
                {{/if}}
                {{!-- Icon buttons grouped so when the audio pill expands
                     on play, all three icons wrap together to the next
                     line instead of breaking one-by-one. --}}
                <div class="article-actions-icons">
                    {{#if @custom.kit_worker_url}}
                        <button class="article-bookmark" type="button"
                                data-article-bookmark
                                data-post-id="{{id}}"
                                aria-label="Bookmark this essay"
                                aria-pressed="false">
                            <svg class="article-bookmark-icon" viewBox="0 0 24 24" aria-hidden="true">
                                <path class="article-bookmark-outline" d="M6 3h12v18l-6-4-6 4V3z" fill="none" stroke="currentColor" stroke-width="2"/>
                                <path class="article-bookmark-fill" d="M6 3h12v18l-6-4-6 4V3z" fill="currentColor"/>
                            </svg>
                            <span class="article-bookmark-label">Bookmark</span>
                        </button>
                    {{/if}}
                    <a class="article-pdf" href="#"
                       data-article-pdf
                       data-post-id="{{id}}"
                       data-post-slug="{{slug}}"
                       aria-label="Download PDF of this essay"
                       download>
                        <svg class="article-pdf-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" fill="none" stroke="currentColor" stroke-width="2"/>
                            <path d="M14 2v6h6" fill="none" stroke="currentColor" stroke-width="2"/>
                        </svg>
                        <span class="article-pdf-label">Download PDF</span>
                    </a>
                    {{!-- Gift link: any signed-in member (Subscriber or Member)
                         can copy a shareable URL that bypasses the soft gate
                         for the recipient. Hidden for signed-out visitors. --}}
                    {{#if @member}}
                    {{#if @custom.gift_worker_url}}
                    <button class="article-gift" type="button"
                            data-article-gift
                            data-post-id="{{id}}"
                            data-post-url="{{url absolute="true"}}"
                            data-member-email="{{@member.email}}"
                            data-worker-url="{{@custom.gift_worker_url}}"
                            aria-label="Gift this essay">
                        <svg class="article-gift-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M3 9h18v4H3z" fill="none" stroke="currentColor" stroke-width="2"/>
                            <path d="M5 13v8h14v-8" fill="none" stroke="currentColor" stroke-width="2"/>
                            <path d="M12 9v12" fill="none" stroke="currentColor" stroke-width="2"/>
                            <path d="M12 9c-2-3-6-3-6-1s2 3 6 1zM12 9c2-3 6-3 6-1s-2 3-6 1z" fill="none" stroke="currentColor" stroke-width="2"/>
                        </svg>
                        <span class="article-gift-label">Gift this essay</span>
                    </button>
                    {{/if}}
                    {{/if}}
                </div>
            </div>
        </div>
    </header>

    {{#if feature_image}}
        <div class="article-feature-img">
            <div class="article-feature-img-inner" style="background-image: url({{img_url feature_image size="xl"}}); background-size: cover; background-position: center;"></div>
            {{#if feature_image_caption}}
                <p class="article-feature-caption">{{{feature_image_caption}}}</p>
            {{/if}}
        </div>
    {{/if}}

    {{!-- Mobile-only TOC slot. JS populates both this and the desktop rail from
         the article's <h2> headings. Hidden on desktop via CSS; hidden on mobile
         when empty so posts without subheads don't show an empty container. --}}
    <nav class="toc-mobile" aria-label="In this essay" data-toc hidden>
        <p class="toc-label">In this essay</p>
        <ol class="toc-list" data-toc-list></ol>
    </nav>

    <div class="article-body">
        <div class="article-body-inner">

            <aside class="article-rail" aria-label="Share">
                <div>
                    <div class="rail-label">Share</div>
                    <div class="share-buttons" style="margin-top: 12px;">
                        <a class="share-btn" href="https://twitter.com/intent/tweet?url={{url absolute="true"}}&text={{encode title}}" target="_blank" rel="noopener" title="Share on X" aria-label="Share on X">X</a>
                        <a class="share-btn" href="https://www.facebook.com/sharer/sharer.php?u={{url absolute="true"}}" target="_blank" rel="noopener" title="Share on Facebook" aria-label="Share on Facebook">f</a>
                        <a class="share-btn" href="mailto:?subject={{encode title}}&body={{url absolute="true"}}" title="Email this essay" aria-label="Email">@</a>
                        <button class="share-btn" type="button" onclick="navigator.clipboard&&navigator.clipboard.writeText('{{url absolute="true"}}');" title="Copy link" aria-label="Copy link">&infin;</button>
                    </div>
                </div>
            </aside>

            {{!-- Soft subscriber gate. The data-* attributes feed
                 assets/js/post-gate.js, which after @custom.gate_days
                 has elapsed truncates the article to the first five
                 paragraphs and injects a sign-up / upgrade card.
                 Bypassable via View Source — this is a nudge, not a
                 real paywall. For enforced access control we'll
                 promote to a worker that flips post visibility. --}}
            <div class="article-content"
                 data-post-gate
                 data-published-at="{{published_at}}"
                 data-gate-days="{{#if @custom.gate_days}}{{@custom.gate_days}}{{else}}0{{/if}}"
                 data-gate-tier="{{#if @custom.gate_tier}}{{@custom.gate_tier}}{{else}}members{{/if}}"
                 data-is-member="{{#if @member}}true{{else}}false{{/if}}"
                 data-member-status="{{#if @member}}{{@member.status}}{{/if}}"
                 data-post-visibility="{{visibility}}">
                {{content}}

                {{#unless @member}}
                    <div class="inline-support">
                        <p class="eyebrow">A Reader-Supported Publication</p>
                        <h3><em>You're reading the kind of essay we exist to publish.</em></h3>
                        <p>
                            {{@site.title}} publishes long-form essays on theology, culture, and spiritual formation because readers like you make them possible. If this piece is worth your time, consider supporting the work.
                        </p>
                        <div class="inline-support-ctas">
                            <a href="#join" class="btn btn-primary">Become a Member</a>
                        </div>
                    </div>
                {{/unless}}
            </div>

            <aside class="article-rail article-rail-toc" aria-label="Contents" data-toc hidden>
                <div>
                    <div class="rail-label">In this essay</div>
                    <ol class="toc-list" data-toc-list></ol>
                </div>
            </aside>

        </div>

        <div class="container-narrow">
            {{!-- Contributor bio block mirrors the byline override: any author- tag replaces
                 the staff author bio. One bio block per contributor tag on the post. --}}
            <div class="author-bio-contributors" data-bio>
                {{#foreach tags}}
                    <div class="author-bio author-bio--candidate" data-tag-slug="{{slug}}">
                        <div class="flourish">{{> "flourish-mark"}}</div>
                        <div class="author-bio-layout">
                            <div class="author-bio-portrait" aria-hidden="true">
                                {{#if feature_image}}
                                    <img src="{{img_url feature_image size="s"}}" alt="" />
                                {{else}}
                                    <span class="author-bio-initial">{{name}}</span>
                                {{/if}}
                            </div>
                            <div class="author-bio-text-col">
                                <p class="eyebrow">The Author</p>
                                <h4 class="author-bio-name"><em>{{name}}</em></h4>
                                {{#if description}}<p class="author-bio-text">{{description}}</p>{{/if}}
                                <p class="author-bio-links"><a href="{{url}}">More essays by {{name}} &rarr;</a></p>
                            </div>
                        </div>
                    </div>
                {{/foreach}}
            </div>
            <div class="author-bio-fallback">
                {{#primary_author}}
                    <div class="author-bio">
                        <div class="flourish">{{> "flourish-mark"}}</div>
                        <div class="author-bio-layout">
                            <div class="author-bio-portrait" aria-hidden="true">
                                {{#if profile_image}}
                                    <img src="{{img_url profile_image size="s"}}" alt="" />
                                {{else}}
                                    <span class="author-bio-initial">{{name}}</span>
                                {{/if}}
                            </div>
                            <div class="author-bio-text-col">
                                <p class="eyebrow">The Author</p>
                                <h4 class="author-bio-name"><em>{{name}}</em></h4>
                                {{#if bio}}<p class="author-bio-text">{{bio}}</p>{{/if}}
                                <p class="author-bio-links">
                                    <a href="{{url}}">More essays by {{name}} &rarr;</a>
                                    {{#if website}}<a href="{{website}}" target="_blank" rel="noopener">Website</a>{{/if}}
                                    {{#if twitter}}<a href="https://twitter.com/{{twitter}}" target="_blank" rel="noopener">Follow</a>{{/if}}
                                </p>
                            </div>
                        </div>
                    </div>
                {{/primary_author}}
            </div>
        </div>
    </div>
</article>

{{!-- RELATED — visual twin of "This Week" on the homepage. Uses the
     post-entry partial and .week-grid so the card treatment stays
     consistent across the site. Server renders a primary_tag-based
     fallback; assets/js/related.js swaps it for a first-non-author
     tag match when a Content API key is configured. --}}
{{#if primary_tag}}
<section class="related"
         data-related
         data-post-id="{{id}}"
         data-tag-slugs="{{#foreach tags visibility="public"}}{{slug}}{{#unless @last}},{{/unless}}{{/foreach}}">
    <div class="container">
        <div class="section-intro">
            <p class="eyebrow">Read Next</p>
            <h2 class="section-heading"><em>More on this theme.</em></h2>
        </div>

        <div class="flourish">{{> "flourish-mark"}}</div>

        <div class="week-grid" data-related-grid>
            {{#get "posts" filter="tag:{{primary_tag.slug}}+id:-{{id}}" limit="4" include="authors,tags"}}
                {{#foreach posts}}
                    {{> "post-entry"}}
                {{/foreach}}
            {{/get}}
        </div>
    </div>
</section>
{{/if}}

{{!-- Full membership form at the bottom of every post — same partial
     used on the homepage #join anchor and /membership/. Wrapped in a
     .membership.homepage-membership div so it picks up the same
     containing styles the homepage uses. --}}
<div class="membership homepage-membership" id="join">
  {{> "membership-body"}}
</div>

<script src="{{asset "js/toc.js"}}"></script>
<script src="{{asset "js/related.js"}}"></script>
<script src="{{asset "js/post-gate.js"}}"></script>
<script src="{{asset "js/article-audio.js"}}"></script>
<script src="{{asset "js/article-bookmark.js"}}"></script>
<script src="{{asset "js/article-pdf.js"}}"></script>
<script src="{{asset "js/article-gift.js"}}"></script>

{{/post}}
