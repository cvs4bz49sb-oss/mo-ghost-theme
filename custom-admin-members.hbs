{{!< default}}
{{!-- /admin/members/ — membership analytics.
     Page skeleton renders for any signed-in member; the mo-admin
     worker returns 403 if the caller's email isn't a Ghost staff
     user, and admin-members.js surfaces that as a not-authorized
     state. --}}

<main class="admin-page">

  {{#if @member}}
    {{> "admin-members-body"}}
  {{else}}
    {{> "admin-denied"}}
  {{/if}}

</main>

<script src="{{asset "js/admin-members.js"}}"></script>
